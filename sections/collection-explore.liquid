{%- comment -%}
  Section: collection-explore.liquid
  • Tailwind CSS only — zero inline styles
  • Alpine.js for interactivity
  • AJAX filtering & sorting — NO full page reloads
  • Shopify Storefront Filtering (Online Store 2.0)
  • Scroll-to-top only on pagination, NOT on filter/sort change
{%- endcomment -%}

{%- liquid
  assign section_collection = section.settings.collection
  assign collection_obj     = collections[section_collection]
  assign heading            = section.settings.heading | default: 'Explore the collection'
  assign products_per_page  = section.settings.products_per_page | default: 12
  assign enable_filtering   = section.settings.enable_filtering
  assign enable_sorting     = section.settings.enable_sorting

  if collection_obj == blank and collection != blank
    assign collection_obj = collection
  endif

  assign active_filters = collection_obj.active_filters | default: empty
-%}

<section
  id="section-{{ section.id }}"
  class="collection-explore w-full bg-white px-[clamp(1.25rem,5vw,5rem)] py-[clamp(2rem,5vw,6rem)]"
  data-collection-url="{{ collection_obj.url }}"
  data-sort-by="{{ collection_obj.sort_by | escape }}"
  x-data="collectionExplore($el)"
  x-init="init()"
>

  <h2 class="mb-12 font-(--font-primary--family) text-[clamp(2rem,3.5vw,3.8rem)] font-light tracking-tight text-black">
    {{ heading }}
  </h2>

  <div class="flex flex-col gap-10 md:flex-row md:items-start">

    {%- comment -%} ══ SIDEBAR ═════════════════════════════════════════ {%- endcomment -%}
    {%- if enable_filtering -%}
    <aside class="w-full shrink-0 md:sticky md:top-8 md:w-52">

      {%- comment -%} Mobile toggle {%- endcomment -%}
      <button
        class="mb-5 flex w-full items-center justify-between py-2 font-(--font-primary--family) text-xs font-semibold uppercase tracking-[0.25em] text-black md:hidden"
        @click="mobileFiltersOpen = !mobileFiltersOpen"
        :aria-expanded="mobileFiltersOpen.toString()"
      >
        <span>Filters</span>
        <svg class="h-3.5 w-3.5 transition-transform duration-300" :class="mobileFiltersOpen ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>

      <div
        class="flex flex-col gap-8"
        :class="mobileFiltersOpen ? 'flex' : 'hidden md:flex md:flex-col'"
      >

        {%- comment -%} ── Shopify Storefront Filters ──────────────── {%- endcomment -%}
        {%- if collection_obj.filters.size > 0 -%}
          {%- for filter in collection_obj.filters -%}
            <div class="flex flex-col gap-3.5">

              <p class="font-(--font-primary--family) text-[0.65rem] font-semibold uppercase tracking-[0.28em] text-black">
                {{ filter.label }}
              </p>

              {%- case filter.type -%}

              {%- when 'list' -%}
                <div class="flex flex-col gap-2.5">
                  {%- for filter_value in filter.values -%}
                    <label class="group flex cursor-pointer items-center gap-3">
                      <input
                        type="checkbox"
                        name="{{ filter_value.param_name }}"
                        value="{{ filter_value.value }}"
                        {% if filter_value.active %}checked{% endif %}
                        {% if filter_value.count == 0 and filter_value.active == false %}disabled{% endif %}
                        class="h-3 w-3 shrink-0 accent-black"
                        @change="applyFilters()"
                      >
                      <span class="font-(--font-primary--family) text-[0.72rem] leading-none text-[#555] transition-colors group-hover:text-black">
                        {{ filter_value.label }}
                        {%- if section.settings.show_filter_count -%}
                          <span class="text-[#ccc]"> ({{ filter_value.count }})</span>
                        {%- endif -%}
                      </span>
                    </label>
                  {%- endfor -%}
                </div>

              {%- when 'price_range' -%}
                <div
                  class="flex flex-col gap-4"
                  x-data="{
                    minVal: {{ filter.min_value.value | default: filter.range_min | divided_by: 100.0 }},
                    maxVal: {{ filter.max_value.value | default: filter.range_max | divided_by: 100.0 }},
                    rangeMin: {{ filter.range_min | divided_by: 100.0 }},
                    rangeMax: {{ filter.range_max | divided_by: 100.0 }},
                    minName: '{{ filter.min_value.param_name }}',
                    maxName: '{{ filter.max_value.param_name }}'
                  }"
                >
                  <div class="flex items-center gap-2">
                    <div class="flex flex-1 flex-col gap-1.5">
                      <span class="font-(--font-primary--family) text-[0.58rem] uppercase tracking-[0.2em] text-[#aaa]">Min</span>
                      <div class="flex items-center gap-1 bg-[#f5f5f5] px-2.5 py-2">
                        <span class="font-(--font-primary--family) text-[0.68rem] text-[#aaa]">{{ cart.currency.symbol }}</span>
                        <input
                          type="number"
                          class="w-full bg-transparent font-(--font-primary--family) text-[0.75rem] text-black outline-none"
                          :min="rangeMin" :max="maxVal - 1" step="1"
                          x-model.number="minVal"
                          :name="minName"
                          @change="minVal = Math.min(minVal, maxVal - 1); applyFilters()"
                        >
                      </div>
                    </div>
                    <span class="mt-5 font-(--font-primary--family) text-[0.6rem] text-[#ccc]">—</span>
                    <div class="flex flex-1 flex-col gap-1.5">
                      <span class="font-(--font-primary--family) text-[0.58rem] uppercase tracking-[0.2em] text-[#aaa]">Max</span>
                      <div class="flex items-center gap-1 bg-[#f5f5f5] px-2.5 py-2">
                        <span class="font-(--font-primary--family) text-[0.68rem] text-[#aaa]">{{ cart.currency.symbol }}</span>
                        <input
                          type="number"
                          class="w-full bg-transparent font-(--font-primary--family) text-[0.75rem] text-black outline-none"
                          :min="minVal + 1" :max="rangeMax" step="1"
                          x-model.number="maxVal"
                          :name="maxName"
                          @change="maxVal = Math.max(maxVal, minVal + 1); applyFilters()"
                        >
                      </div>
                    </div>
                  </div>

                  <div class="relative h-[3px] w-full rounded-full bg-[#e8e8e8]">
                    <div
                      class="absolute top-0 h-full rounded-full bg-black"
                      :style="`left:${((minVal - rangeMin) / (rangeMax - rangeMin)) * 100}%; right:${((rangeMax - maxVal) / (rangeMax - rangeMin)) * 100}%`"
                    ></div>
                    <input
                      type="range"
                      class="pointer-events-none absolute inset-0 h-full w-full cursor-pointer appearance-none bg-transparent [&::-webkit-slider-thumb]:pointer-events-auto [&::-webkit-slider-thumb]:h-3.5 [&::-webkit-slider-thumb]:w-3.5 [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:bg-black [&::-webkit-slider-thumb]:transition-transform [&::-webkit-slider-thumb]:hover:scale-125 [&::-moz-range-thumb]:h-3.5 [&::-moz-range-thumb]:w-3.5 [&::-moz-range-thumb]:rounded-full [&::-moz-range-thumb]:border-0 [&::-moz-range-thumb]:bg-black"
                      :min="rangeMin" :max="rangeMax" step="1"
                      x-model.number="minVal"
                      :name="minName"
                      @input="minVal = Math.min(minVal, maxVal - 1)"
                      @change="applyFilters()"
                    >
                    <input
                      type="range"
                      class="pointer-events-none absolute inset-0 h-full w-full cursor-pointer appearance-none bg-transparent [&::-webkit-slider-thumb]:pointer-events-auto [&::-webkit-slider-thumb]:h-3.5 [&::-webkit-slider-thumb]:w-3.5 [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:bg-black [&::-webkit-slider-thumb]:transition-transform [&::-webkit-slider-thumb]:hover:scale-125 [&::-moz-range-thumb]:h-3.5 [&::-moz-range-thumb]:w-3.5 [&::-moz-range-thumb]:rounded-full [&::-moz-range-thumb]:border-0 [&::-moz-range-thumb]:bg-black"
                      :min="rangeMin" :max="rangeMax" step="1"
                      x-model.number="maxVal"
                      :name="maxName"
                      @input="maxVal = Math.max(maxVal, minVal + 1)"
                      @change="applyFilters()"
                    >
                  </div>
                </div>

              {%- endcase -%}
            </div>
          {%- endfor -%}
        {%- endif -%}

        {%- comment -%} ── Schema block fallback filter groups ─────── {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'filter_group' -%}
            <div class="flex flex-col gap-3.5" {{ block.shopify_attributes }}>
              <p class="font-(--font-primary--family) text-[0.65rem] font-semibold uppercase tracking-[0.28em] text-black">
                {{ block.settings.label }}
              </p>
              <div class="flex flex-col gap-2.5">
                {%- assign filter_values = block.settings.values | split: ',' -%}
                {%- for val in filter_values -%}
                  <label class="group flex cursor-pointer items-center gap-3">
                    <input
                      type="checkbox"
                      class="h-3 w-3 shrink-0 accent-black"
                      @change="applyFilters()"
                    >
                    <span class="font-(--font-primary--family) text-[0.72rem] text-[#555] transition-colors group-hover:text-black">{{ val | strip }}</span>
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} ── Active filter pills ──────────────────────── {%- endcomment -%}
        {%- if active_filters.size > 0 -%}
          <div class="flex flex-col gap-2.5 pt-1">
            <p class="font-(--font-primary--family) text-[0.6rem] font-semibold uppercase tracking-[0.25em] text-[#bbb]">Active filters</p>
            <div class="flex flex-wrap gap-1.5">
              {%- for active_filter in active_filters -%}
                <button
                  class="flex items-center gap-1.5 bg-black px-2.5 py-1 font-(--font-primary--family) text-[0.6rem] uppercase tracking-[0.1em] text-white transition-opacity hover:opacity-60"
                  @click="removeFilter('{{ active_filter.url_to_remove | escape }}')"
                  type="button"
                >
                  {{ active_filter.label }}: {{ active_filter.value.label | default: active_filter.value }}
                  <svg class="h-2 w-2 shrink-0" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M2 2l8 8M10 2L2 10"/>
                  </svg>
                </button>
              {%- endfor -%}
              <button
                type="button"
                class="font-(--font-primary--family) text-[0.6rem] uppercase tracking-[0.18em] text-[#bbb] underline underline-offset-2 transition-colors hover:text-black"
                @click="clearAllFilters()"
              >
                Clear all
              </button>
            </div>
          </div>
        {%- endif -%}

      </div>
    </aside>
    {%- endif -%}

    {%- comment -%} ══ MAIN ════════════════════════════════════════════ {%- endcomment -%}
    <div class="min-w-0 flex-1">

      {%- comment -%} ── Tabs ────────────────────────────────────────── {%- endcomment -%}
      {%- if enable_sorting -%}
        <div class="mb-10 flex items-center gap-8">
          <button
            class="relative pb-1 font-(--font-primary--family) text-[0.7rem] font-semibold uppercase tracking-[0.22em] transition-colors duration-200 after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:origin-left after:bg-black after:transition-transform after:duration-300"
            :class="activeTab === 'all' ? 'text-black after:scale-x-100' : 'text-[#bbb] after:scale-x-0 hover:text-black'"
            @click="activeTab = 'all'; applySort('manual')"
          >
            All<sup class="ml-0.5 text-[0.5rem]">{{ collection_obj.products_count }}</sup>
          </button>
          <button
            class="relative pb-1 font-(--font-primary--family) text-[0.7rem] font-semibold uppercase tracking-[0.22em] transition-colors duration-200 after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:origin-left after:bg-black after:transition-transform after:duration-300"
            :class="activeTab === 'best' ? 'text-black after:scale-x-100' : 'text-[#bbb] after:scale-x-0 hover:text-black'"
            @click="activeTab = 'best'; applySort('best-selling')"
          >
            Best sellers
          </button>
          <button
            class="relative pb-1 font-(--font-primary--family) text-[0.7rem] font-semibold uppercase tracking-[0.22em] transition-colors duration-200 after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:origin-left after:bg-black after:transition-transform after:duration-300"
            :class="activeTab === 'new' ? 'text-black after:scale-x-100' : 'text-[#bbb] after:scale-x-0 hover:text-black'"
            @click="activeTab = 'new'; applySort('created-desc')"
          >
            New arrivals
          </button>
        </div>
      {%- endif -%}

      {%- comment -%} ── Loading ──────────────────────────────────────── {%- endcomment -%}
      <div x-show="loading" x-cloak class="flex min-h-64 w-full items-center justify-center">
        <div class="h-4 w-4 animate-spin rounded-full border border-black border-t-transparent"></div>
      </div>

      {%- comment -%} ── Results ─────────────────────────────────────── {%- endcomment -%}
      {%- paginate collection_obj.products by products_per_page -%}

      <div
        id="collection-results-{{ section.id }}"
        x-show="!loading"
        class="w-full"
      >
          {%- if collection_obj.products.size > 0 -%}

            {%- comment -%}
              CSS columns masonry:
              — 2 columns on mobile, 3 on desktop
              — col_pos 1 (middle column on desktop) gets card--offset → shorter image
            {%- endcomment -%}
            <div class="columns-2 gap-x-3 md:columns-3 md:gap-x-5">
              {%- for product in collection_obj.products -%}
                {%- assign col_pos = forloop.index0 | modulo: 3 -%}
                <div class="
                  break-inside-avoid mb-3 md:mb-5
                  opacity-0 translate-y-3
                  animate-[cardReveal_0.45s_ease_forwards]
                  [animation-delay:calc({{ forloop.index0 }}*50ms)]
                  {% if col_pos == 1 %}card--offset{% endif %}
                ">
                  {% render 'product-card',
                    product: product,
                    lazy: forloop.index > 4,
                    show_vendor: section.settings.show_vendor
                  %}
                </div>
              {%- endfor -%}
            </div>

          {%- else -%}
            <div class="flex min-h-64 flex-col items-center justify-center gap-4 text-center">
              <p class="font-(--font-primary--family) text-base font-light text-[#bbb]">No products found.</p>
              {%- if active_filters.size > 0 -%}
                <button
                  type="button"
                  class="font-(--font-primary--family) text-[0.7rem] font-semibold uppercase tracking-widest text-black underline underline-offset-4 transition-opacity hover:opacity-50"
                  @click="clearAllFilters()"
                >
                  Clear filters
                </button>
              {%- endif -%}
            </div>
          {%- endif -%}

        {%- comment -%} ── Pagination ──────────────────────────────── {%- endcomment -%}
        {%- if paginate.pages > 1 -%}
          <nav class="mt-16 flex items-center justify-center gap-1.5" aria-label="Pagination">
            {%- if paginate.previous -%}
              <button
                type="button"
                class="px-5 py-2 font-(--font-primary--family) text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-black transition-opacity hover:opacity-40"
                @click="fetchPage('{{ paginate.previous.url | escape }}')"
              >
                ← Prev
              </button>
            {%- endif -%}

            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <button
                  type="button"
                  class="flex h-8 w-8 items-center justify-center font-(--font-primary--family) text-[0.65rem] font-semibold text-[#bbb] transition-colors hover:text-black"
                  @click="fetchPage('{{ part.url | escape }}')"
                >
                  {{ part.title }}
                </button>
              {%- else -%}
                {%- if part.title == paginate.current_page -%}
                  <span class="flex h-8 w-8 items-center justify-center bg-black font-(--font-primary--family) text-[0.65rem] font-semibold text-white">
                    {{ part.title }}
                  </span>
                {%- else -%}
                  <span class="flex h-8 w-8 items-center justify-center font-(--font-primary--family) text-[0.65rem] text-[#ddd]">
                    {{ part.title }}
                  </span>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}

            {%- if paginate.next -%}
              <button
                type="button"
                class="px-5 py-2 font-(--font-primary--family) text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-black transition-opacity hover:opacity-40"
                @click="fetchPage('{{ paginate.next.url | escape }}')"
              >
                Next →
              </button>
            {%- endif -%}
          </nav>
        {%- endif -%}
      </div>

      {%- endpaginate -%}
    </div>
  </div>
</section>

<script>
  function collectionExplore(rootEl) {
    return {
      mobileFiltersOpen: false,
      activeTab: 'all',
      loading: false,
      root: rootEl,
      collectionUrl: rootEl.dataset.collectionUrl || '',
      sortBy: rootEl.dataset.sortBy || 'manual',
      sectionId: rootEl.id.replace('section-', ''),

      init() {
        const s = new URLSearchParams(window.location.search).get('sort_by') || this.sortBy;
        if (s === 'best-selling')      this.activeTab = 'best';
        else if (s === 'created-desc') this.activeTab = 'new';
        else                           this.activeTab = 'all';
        this.sortBy = s;
      },

      /* ── Core fetch: replaces results AND sidebar from server HTML ── */
      async fetchPage(url, scrollToTop) {
        this.loading = true;
        if (scrollToTop) window.scrollTo({ top: 0, behavior: 'smooth' });
        try {
          const res  = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
          const html = await res.text();
          const doc  = new DOMParser().parseFromString(html, 'text/html');

          /* Replace product results */
          const nextResults = doc.getElementById('collection-results-' + this.sectionId);
          const curResults  = document.getElementById('collection-results-' + this.sectionId);
          if (nextResults && curResults) curResults.innerHTML = nextResults.innerHTML;

          /* Replace sidebar so checkboxes reflect server-confirmed active state */
          const nextSidebar = doc.querySelector('#section-' + this.sectionId + ' aside');
          const curSidebar  = this.root.querySelector('aside');
          if (nextSidebar && curSidebar) {
            const wasOpen = this.mobileFiltersOpen;
            curSidebar.innerHTML = nextSidebar.innerHTML;
            /* Re-attach Alpine @change listeners after innerHTML swap */
            curSidebar.querySelectorAll('input[type="checkbox"]').forEach(cb => {
              cb.addEventListener('change', () => this.applyFilters());
            });
            curSidebar.querySelectorAll('input[type="number"], input[type="range"]').forEach(inp => {
              inp.addEventListener('change', () => this.applyFilters());
            });
            this.mobileFiltersOpen = wasOpen;
          }

          history.pushState({}, '', url);
        } catch (e) {
          console.error('[collection-explore] fetch failed:', e);
        } finally {
          this.loading = false;
        }
      },

      /* ── Build URL purely from current sidebar DOM state ── */
      buildFilterUrl() {
        const u       = new URL(this.collectionUrl, window.location.origin);
        const sidebar = this.root.querySelector('aside');

        if (sidebar) {
          /* Checkboxes */
          sidebar.querySelectorAll('input[type="checkbox"]:checked').forEach(cb => {
            if (cb.name) u.searchParams.append(cb.name, cb.value);
          });

          /* Price range — number inputs take priority, range inputs fill gaps */
          const seen = new Set();
          sidebar.querySelectorAll('input[type="number"]').forEach(inp => {
            if (inp.name && inp.value !== '') {
              u.searchParams.set(inp.name, inp.value);
              seen.add(inp.name);
            }
          });
          sidebar.querySelectorAll('input[type="range"]').forEach(inp => {
            if (inp.name && inp.value !== '' && !seen.has(inp.name)) {
              u.searchParams.set(inp.name, inp.value);
            }
          });
        }

        if (this.sortBy && this.sortBy !== 'manual') {
          u.searchParams.set('sort_by', this.sortBy);
        }

        return u.toString();
      },

      applyFilters() {
        this.fetchPage(this.buildFilterUrl(), false);
      },

      applySort(val) {
        this.sortBy = val;
        this.fetchPage(this.buildFilterUrl(), false);
      },

      /* Shopify gives us a ready-made URL with that filter already removed */
      removeFilter(urlToRemove) {
        this.fetchPage(urlToRemove, false);
      },

      clearAllFilters() {
        const u = new URL(this.collectionUrl, window.location.origin);
        if (this.sortBy && this.sortBy !== 'manual') u.searchParams.set('sort_by', this.sortBy);
        this.fetchPage(u.toString(), false);
      },
    }
  }
</script>

<style>
  @keyframes cardReveal {
    from { opacity: 0; transform: translateY(0.75rem); }
    to   { opacity: 1; transform: translateY(0); }
  }
  [x-cloak] { display: none !important; }

  /* Default image height — 1st & 3rd column (tall) */
  .product-card-image {
    height: 56vw;
  }
  /* 2nd column — shorter on ALL screen sizes */
  .card--offset .product-card-image {
    height: 38vw;
  }

  @media (min-width: 768px) {
    .product-card-image {
      height: 28vw;
    }
    .card--offset .product-card-image {
      height: 19vw;
    }
  }
</style>

{% schema %}
{
  "name": "Collection Explore",
  "tag": "section",
  "class": "section-collection-explore",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Explore the collection" },
    { "type": "collection", "id": "collection", "label": "Collection", "info": "Leave blank to use current collection page." },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 6, "max": 48, "step": 3, "default": 12 },
    { "type": "header", "content": "Product card" },
    { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": false },
    { "type": "checkbox", "id": "show_filter_count", "label": "Show filter counts", "default": true },
    { "type": "header", "content": "Filtering & Sorting" },
    { "type": "checkbox", "id": "enable_filtering", "label": "Enable Storefront filtering", "default": true, "info": "Requires filters in Shopify Admin > Navigation > Search & Discovery." },
    { "type": "checkbox", "id": "enable_sorting", "label": "Enable sorting tabs", "default": true }
  ],
  "blocks": [
    {
      "type": "filter_group",
      "name": "Filter group (fallback)",
      "settings": [
        { "type": "text", "id": "label", "label": "Group label", "default": "Models" },
        { "type": "text", "id": "values", "label": "Values (comma-separated)", "default": "Option A, Option B, Option C" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Explore",
      "blocks": [
        { "type": "filter_group", "settings": { "label": "Models", "values": "Classic, Pro, Slim, XL" } },
        { "type": "filter_group", "settings": { "label": "Color", "values": "Orange, Black, Blue, White" } }
      ]
    }
  ]
}
{% endschema %}