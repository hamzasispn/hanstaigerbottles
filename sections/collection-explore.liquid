{%- comment -%}
  Section: collection-explore.liquid
  ─────────────────────────────────────────────────────
  • Tailwind CSS (via CDN — swap for your build pipeline)
  • Alpine.js  (via CDN — swap for your bundle)
  • Shopify Storefront Filtering  (requires Online Store 2.0)
  • Product card rendered via snippet 'product-card'
  • Collection selectable in Customizer
  • vw-based responsive sizing throughout
{%- endcomment -%}

{%- liquid
  assign section_collection = section.settings.collection
  assign collection_obj     = collections[section_collection]
  assign heading            = section.settings.heading | default: 'Explore the collection'
  assign products_per_page  = section.settings.products_per_page | default: 12
  assign enable_filtering   = section.settings.enable_filtering
  assign enable_sorting     = section.settings.enable_sorting

  if collection_obj == blank and collection != blank
    assign collection_obj = collection
  endif

  assign current_filter_url = collection_obj.url | append: '?'
  assign active_filters = collection_obj.active_filters | default: empty
-%}

{%- comment -%} ══════════════════════════════════════════════
    CDN assets — remove if already loaded in theme.liquid
═══════════════════════════════════════════════════ {%- endcomment -%}
<link  href="https://cdn.jsdelivr.net/npm/tailwindcss@3/dist/tailwind.min.css" rel="stylesheet">
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3/dist/cdn.min.js"></script>

<style>
  /* ── vw-scaled spacing tokens ──────────────────────── */
  :root {
    --section-px: clamp(1rem, 4vw, 5rem);
    --section-py: clamp(2rem, 5vw, 6rem);
    --card-gap:   clamp(0.75rem, 1.5vw, 1.5rem);
    --sidebar-w:  clamp(11rem, 16vw, 18rem);
  }

  /* ── Filter sidebar ─────────────────────────────────── */
  .filter-section summary {
    list-style: none;
  }
  .filter-section summary::-webkit-details-marker { display: none; }

  /* ── Active filter pill ─────────────────────────────── */
  .active-filter-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.2rem 0.65rem;
    border: 1px solid #ccc;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.15s;
  }
  .active-filter-pill:hover { background: #f0f0f0; }

  /* ── Tab underline ──────────────────────────────────── */
  .tab-btn { position: relative; }
  .tab-btn::after {
    content: '';
    position: absolute;
    bottom: -2px; left: 0;
    width: 100%; height: 1.5px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.2s ease;
  }
  .tab-btn[aria-selected="true"]::after { transform: scaleX(1); }

  /* ── Product grid masonry feel via row-span ─────────── */
  @media (min-width: 768px) {
    .product-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: min-content;
      gap: var(--card-gap);
    }
    /* Every 7th card (0-indexed: 0, 6, 12…) spans left column wide */
    .product-grid > article:nth-child(7n+1) {
      grid-column: 1;
      grid-row: span 2;
    }
  }

  /* ── Scroll-fade-in cards ───────────────────────────── */
  @keyframes cardReveal {
    from { opacity: 0; transform: translateY(1.5vw); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .product-card {
    animation: cardReveal 0.45s ease both;
  }
  .product-card:nth-child(1)  { animation-delay: 0.00s; }
  .product-card:nth-child(2)  { animation-delay: 0.05s; }
  .product-card:nth-child(3)  { animation-delay: 0.10s; }
  .product-card:nth-child(4)  { animation-delay: 0.15s; }
  .product-card:nth-child(5)  { animation-delay: 0.20s; }
  .product-card:nth-child(6)  { animation-delay: 0.25s; }
  .product-card:nth-child(n+7){ animation-delay: 0.30s; }

  [x-cloak] { display: none !important; }
</style>

{%- comment -%} ══════════════════════════════════════════════
    SECTION ROOT
═══════════════════════════════════════════════════ {%- endcomment -%}
<section
  id="section-{{ section.id }}"
  class="collection-explore w-full bg-white font-[system-ui]"
  style="padding: var(--section-py) var(--section-px);"
  x-data="{
    mobileFiltersOpen: false,
    activeTab: 'all',
    sortBy: '{{ collection_obj.sort_by | escape }}',
    sortOptions: {{ collection_obj.sort_options | map: 'name' | json }},

    /* Build URL with sort param */
    applySort(val) {
      const u = new URL(window.location.href);
      u.searchParams.set('sort_by', val);
      window.location.href = u.toString();
    }
  }"
>

  {%- comment -%} ── Section heading ───────────────────────────────── {%- endcomment -%}
  <h2 class="mb-[3vw] text-[clamp(1.6rem,3.2vw,3rem)] font-light leading-tight tracking-tight text-black">
    {{ heading }}
  </h2>

  {%- comment -%} ── Layout: sidebar + main ────────────────────────── {%- endcomment -%}
  <div class="flex flex-col gap-[3vw] md:flex-row md:items-start">

    {%- comment -%} ════════════════════════════════════════════════════
        SIDEBAR — FILTERS
    ════════════════════════════════════════════════════ {%- endcomment -%}
    <aside
      class="shrink-0 md:sticky md:top-6"
      style="width: var(--sidebar-w);"
      x-show="true"
    >

      {%- comment -%} Mobile toggle {%- endcomment -%}
      <button
        class="mb-3 flex w-full items-center justify-between border border-black px-3 py-2 text-[0.65rem] font-semibold uppercase tracking-[0.2em] md:hidden"
        @click="mobileFiltersOpen = !mobileFiltersOpen"
        :aria-expanded="mobileFiltersOpen"
      >
        Filters
        <svg class="h-3 w-3 transition-transform" :class="mobileFiltersOpen ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>

      <div class="hidden md:block" x-show="mobileFiltersOpen || window.matchMedia('(min-width:768px)').matches" x-cloak>
        <div class="flex flex-col divide-y divide-[#e0e0e0]">

          {%- comment -%} ── Storefront filter groups ─────────────────── {%- endcomment -%}
          {%- if enable_filtering and collection_obj.filters.size > 0 -%}
            {%- for filter in collection_obj.filters -%}
              <details
                class="filter-section group py-[1.2vw] first:pt-0"
                {% if forloop.index <= 2 %}open{% endif %}
              >
                <summary class="flex cursor-pointer select-none items-center justify-between">
                  <span class="text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-black">
                    {{ filter.label }}
                  </span>
                  <span class="text-[0.8rem] text-[#666] transition-transform duration-200 group-open:rotate-45">+</span>
                </summary>

                <div class="mt-[0.8vw] flex flex-col gap-y-[0.5vw]">

                  {%- case filter.type -%}

                  {%- comment -%} ── List filter (Model, Color, etc.) ────── {%- endcomment -%}
                  {%- when 'list' -%}
                    {%- for filter_value in filter.values -%}
                      <label class="flex cursor-pointer items-center gap-x-2 group/label">
                        <input
                          type="checkbox"
                          name="{{ filter_value.param_name }}"
                          value="{{ filter_value.value }}"
                          {% if filter_value.active %}checked{% endif %}
                          {% if filter_value.count == 0 and filter_value.active == false %}disabled{% endif %}
                          class="h-3 w-3 accent-black"
                          hx-get="{{ filter_value.url_to_add }}"
                          onchange="this.form.requestSubmit ? this.form.requestSubmit() : this.form.submit()"
                        >
                        <span class="text-[0.65rem] text-[#333] group-hover/label:text-black">
                          {{ filter_value.label }}
                          {%- if section.settings.show_filter_count -%}
                            <span class="text-[#aaa]">({{ filter_value.count }})</span>
                          {%- endif -%}
                        </span>
                      </label>
                    {%- endfor -%}

                  {%- comment -%} ── Price range filter ───────────────────── {%- endcomment -%}
                  {%- when 'price_range' -%}
                    {%- liquid
                      assign price_min = filter.min_value.value | default: filter.range_min | money_without_currency
                      assign price_max = filter.max_value.value | default: filter.range_max | money_without_currency
                    -%}
                    <div
                      class="flex flex-col gap-y-2"
                      x-data="{
                        minVal: {{ filter.min_value.value | default: filter.range_min | divided_by: 100.0 }},
                        maxVal: {{ filter.max_value.value | default: filter.range_max | divided_by: 100.0 }},
                        rangeMin: {{ filter.range_min | divided_by: 100.0 }},
                        rangeMax: {{ filter.range_max | divided_by: 100.0 }}
                      }"
                    >
                      <div class="flex items-center gap-x-1">
                        <span class="text-[0.6rem] text-[#666]">{{ cart.currency.symbol }}<span x-text="minVal"></span></span>
                        <span class="text-[0.6rem] text-[#bbb]">–</span>
                        <span class="text-[0.6rem] text-[#666]">{{ cart.currency.symbol }}<span x-text="maxVal"></span></span>
                      </div>
                      <div class="relative h-[3px] w-full rounded-full bg-[#ddd]">
                        <div
                          class="absolute h-full rounded-full bg-black"
                          :style="`left:${((minVal-rangeMin)/(rangeMax-rangeMin))*100}%; right:${((rangeMax-maxVal)/(rangeMax-rangeMin))*100}%`"
                        ></div>
                        <input
                          type="range"
                          class="price-slider-thumb absolute inset-0 h-full w-full cursor-pointer appearance-none bg-transparent"
                          :min="rangeMin" :max="rangeMax" step="1"
                          x-model.number="minVal"
                          name="{{ filter.min_value.param_name }}"
                        >
                        <input
                          type="range"
                          class="price-slider-thumb absolute inset-0 h-full w-full cursor-pointer appearance-none bg-transparent"
                          :min="rangeMin" :max="rangeMax" step="1"
                          x-model.number="maxVal"
                          name="{{ filter.max_value.param_name }}"
                        >
                      </div>
                    </div>

                  {%- endcase -%}
                </div>
              </details>
            {%- endfor -%}

          {%- else -%}
            {%- comment -%} Fallback static filters when Storefront Filtering not enabled {%- endcomment -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'filter_group' -%}
                <details class="filter-section group py-[1.2vw] first:pt-0" open>
                  <summary class="flex cursor-pointer select-none items-center justify-between">
                    <span class="text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-black">
                      {{ block.settings.label }}
                    </span>
                    <span class="text-[0.8rem] text-[#666] transition-transform duration-200 group-open:rotate-45">+</span>
                  </summary>
                  <div class="mt-[0.8vw]">
                    {%- assign filter_values = block.settings.values | split: ',' -%}
                    {%- for val in filter_values -%}
                      <label class="flex cursor-pointer items-center gap-x-2 py-0.5">
                        <input type="checkbox" class="h-3 w-3 accent-black">
                        <span class="text-[0.65rem] text-[#333]">{{ val | strip }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </details>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}

        </div>
      </div>
    </aside>

    {%- comment -%} ════════════════════════════════════════════════════
        MAIN CONTENT
    ════════════════════════════════════════════════════ {%- endcomment -%}
    <div class="min-w-0 flex-1">

      {%- comment -%} ── Top toolbar: tabs + clear + sort ─────────────── {%- endcomment -%}
      <div class="mb-[2vw] flex flex-wrap items-center justify-between gap-y-3 border-b border-[#e0e0e0] pb-3">

        {%- comment -%} Tabs / sort_by groups {%- endcomment -%}
        <div class="flex items-center gap-x-[2vw]">
          <button
            class="tab-btn text-[0.6rem] font-semibold uppercase tracking-[0.2em] text-black"
            :aria-selected="activeTab === 'all'"
            @click="activeTab = 'all'; applySort('manual')"
          >
            All<sup class="ml-0.5 text-[0.5rem] text-[#888]">{{ collection_obj.products_count }}</sup>
          </button>

          {%- if enable_sorting -%}
            <button
              class="tab-btn text-[0.6rem] font-semibold uppercase tracking-[0.2em] text-[#777] hover:text-black"
              :aria-selected="activeTab === 'best'"
              @click="activeTab = 'best'; applySort('best-selling')"
            >
              Best sellers<sup class="ml-0.5 text-[0.5rem] text-[#888]"></sup>
            </button>

            <button
              class="tab-btn text-[0.6rem] font-semibold uppercase tracking-[0.2em] text-[#777] hover:text-black"
              :aria-selected="activeTab === 'top'"
              @click="activeTab = 'top'; applySort('created-desc')"
            >
              Top rated<sup class="ml-0.5 text-[0.5rem] text-[#888]"></sup>
            </button>
          {%- endif -%}
        </div>

        {%- comment -%} Active filter pills + clear ─────────────────── {%- endcomment -%}
        <div class="flex flex-wrap items-center gap-2">
          {%- if active_filters.size > 0 -%}
            {%- for active_filter in active_filters -%}
              <a href="{{ active_filter.url_to_remove }}" class="active-filter-pill">
                {{ active_filter.label }}: {{ active_filter.value.label | default: active_filter.value }}
                <svg class="h-2.5 w-2.5" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M2 2l8 8M10 2L2 10"/>
                </svg>
              </a>
            {%- endfor -%}
            <a
              href="{{ collection_obj.url }}"
              class="text-[0.58rem] font-semibold uppercase tracking-[0.18em] text-[#888] underline underline-offset-2 hover:text-black"
            >
              Clear all filters<sup>{{ active_filters.size }}</sup>
            </a>
          {%- endif -%}

          {%- comment -%} Sort select ─────────────────────────────────── {%- endcomment -%}
          {%- if enable_sorting and collection_obj.sort_options.size > 0 -%}
            <select
              class="ml-auto border-0 text-[0.58rem] font-semibold uppercase tracking-[0.18em] text-[#555] outline-none ring-0 hover:text-black"
              x-model="sortBy"
              @change="applySort($event.target.value)"
              aria-label="Sort by"
            >
              {%- for sort_option in collection_obj.sort_options -%}
                <option
                  value="{{ sort_option.value }}"
                  {% if collection_obj.sort_by == sort_option.value %}selected{% endif %}
                >
                  {{ sort_option.name }}
                </option>
              {%- endfor -%}
            </select>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ── Filter form (wraps grid for submit) ──────────── {%- endcomment -%}
      {%- paginate collection_obj.products by products_per_page -%}

      <form
        id="collection-filter-form-{{ section.id }}"
        method="get"
        action="{{ collection_obj.url }}"
        class="w-full"
      >
        {%- comment -%} Preserve active sort {%- endcomment -%}
        <input type="hidden" name="sort_by" value="{{ collection_obj.sort_by }}">

        {%- comment -%} ── Product grid ─────────────────────────────────── {%- endcomment -%}
        {%- if collection_obj.products.size > 0 -%}
          <div class="product-grid">
            {%- for product in collection_obj.products -%}
              {% render 'product-card',
                product: product,
                lazy: forloop.index > 3,
                show_vendor: section.settings.show_vendor
              %}
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="flex min-h-[30vw] flex-col items-center justify-center text-center">
            <p class="text-[1.2rem] font-light text-[#aaa]">No products found.</p>
            {%- if active_filters.size > 0 -%}
              <a href="{{ collection_obj.url }}" class="mt-4 text-[0.65rem] font-semibold uppercase tracking-widest underline underline-offset-2">
                Clear filters
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}

      </form>

      {%- comment -%} ── Pagination ───────────────────────────────────── {%- endcomment -%}
      {%- if paginate.pages > 1 -%}
        <nav class="mt-[4vw] flex items-center justify-center gap-x-3" aria-label="Pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="border border-black px-[2vw] py-[0.6vw] text-[0.6rem] font-semibold uppercase tracking-[0.2em] transition-colors hover:bg-black hover:text-white">
              &larr; Prev
            </a>
          {%- endif -%}

          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="border border-[#ccc] px-[1.5vw] py-[0.6vw] text-[0.6rem] font-semibold uppercase tracking-[0.2em] hover:border-black">
                {{ part.title }}
              </a>
            {%- else -%}
              {%- if part.title == paginate.current_page -%}
                <span class="border border-black bg-black px-[1.5vw] py-[0.6vw] text-[0.6rem] font-semibold uppercase tracking-[0.2em] text-white">
                  {{ part.title }}
                </span>
              {%- else -%}
                <span class="text-[0.6rem] text-[#aaa]">{{ part.title }}</span>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="border border-black px-[2vw] py-[0.6vw] text-[0.6rem] font-semibold uppercase tracking-[0.2em] transition-colors hover:bg-black hover:text-white">
              Next &rarr;
            </a>
          {%- endif -%}
        </nav>
      {%- endif -%}

      {%- endpaginate -%}

    </div>{%- comment -%} /main {%- endcomment -%}
  </div>{%- comment -%} /layout {%- endcomment -%}
</section>

{% schema %}
{
  "name": "Collection Explore",
  "tag": "section",
  "class": "section-collection-explore",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore the collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Select the collection to display. Leave blank to use the current collection page."
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 6,
      "max": 48,
      "step": 3,
      "default": 12
    },
    {
      "type": "header",
      "content": "Product card"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_filter_count",
      "label": "Show filter counts",
      "default": true
    },
    {
      "type": "header",
      "content": "Filtering & Sorting"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "Enable Storefront filtering",
      "default": true,
      "info": "Requires filters set up in Shopify Admin → Navigation → Search & Discovery."
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Enable sorting tabs",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "filter_group",
      "name": "Filter group (fallback)",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Group label",
          "default": "Models"
        },
        {
          "type": "text",
          "id": "values",
          "label": "Values (comma-separated)",
          "default": "Option A, Option B, Option C"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Explore",
      "blocks": [
        {
          "type": "filter_group",
          "settings": {
            "label": "Models",
            "values": "Classic, Pro, Slim, XL"
          }
        },
        {
          "type": "filter_group",
          "settings": {
            "label": "Color",
            "values": "Orange, Black, Blue, White"
          }
        }
      ]
    }
  ]
}
{% endschema %}
