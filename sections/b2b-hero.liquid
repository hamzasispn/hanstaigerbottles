<div class="grid grid-cols-1 lg:grid-cols-2">
  <div>
    <img
    src="{{ section.settings.background_image | img_url: '1200x' }}"
    alt="{{ section.settings.background_image.alt | escape }}"
    class="w-full h-[60vw] lg:h-full object-cover"
    >
  </div>
  <div class="py-[10vw] lg:py-[8.75vw] px-[6vw] lg:px-[5.556vw]">
    <div class="flex lg:flex-row flex-col items-start justify-between mb-[8vw] lg:mb-[6.528vw] gap-[4vw]">
      <h2 class="max-w-[60vw] lg:max-w-[24.583vw] text-[10.526vw] leading-[11.579vw] lg:text-[3.333vw] lg:leading-[3.75vw]">{{ section.settings.heading }}</h2>
      <img
        src="{{ section.settings.feature_image | img_url: '1080x'}}"
        alt="{{ section.settings.feature_image.alt | escape }}"
        class="w-[42.105vw] h-[54.737vw] lg:w-[11.111vw] lg:h-[14.444vw] object-cover self-end"
      >
    </div>

    <div class="flex items-center justify-between mb-[8vw] lg:mb-[6.528vw] gap-[3vw]">
      <span class="text-[2.6vw] lg:text-[0.833vw] text-black uppercase font-normal">{{ section.settings.subheading_one }}</span>
      <span class="text-[2.6vw] lg:text-[0.833vw] text-black uppercase font-normal">{{ section.settings.subheading_two }}</span>
    </div>

    <div>
      <h2 class="max-w-[60vw] lg:max-w-[24.583vw] ml-auto text-[6.5vw] leading-[7.5vw] lg:text-[3.333vw] lg:leading-[3.75vw] text-right mb-[3vw] lg:mb-[1.736vw]">
        {{ section.settings.heading_two }}
      </h2>
      <div class="flex flex-col lg:flex-row items-start lg:items-end justify-between gap-[4vw]">
        <p class="text-[#4F5257] text-[3vw] leading-[4vw] lg:text-[0.903vw] lg:leading-[1.181vw] lg:max-w-[22.639vw]">
          {{ section.settings.description }}
        </p>
        <a href="{{ section.settings.button_url }}" class="btn-primary shrink-0">{{ section.settings.button_text }}</a>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "B2B Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "B2B Hero"
    },
    {
      "type": "text",
      "id": "heading_two",
      "label": "Heading Two",
      "default": "B2B Hero"
    },
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Feature Image"
    },
    {
      "type": "text",
      "id": "subheading_one",
      "label": "Subheading One",
      "default": "Engineered objects   /   Lasting impressions"
    },
    {
      "type": "text",
      "id": "subheading_two",
      "label": "Subheading Two",
      "default": "hanstaiger"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "We are a B2B company that specializes in creating high-quality, custom-designed bottles for our clients. Our team of experts works closely with each client to understand their unique needs and create a bottle that is both functional and visually stunning. We use the latest technology and materials to ensure that our bottles are of the highest quality and meet the specific requirements of our clients."
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    }
  ],
  "presets": [
    {
      "name": "B2B Hero"
    }
  ]
}
{% endschema %}
