{%- comment -%}
  Product accordions section.
  Each block renders one accordion row. Content can be a rich-text setting
  or pulled from a product metafield (namespace + key).
{%- endcomment -%}

<section
  class="product-accordions w-full bg-[#F4F4F5] px-[5.333vw] lg:px-[5.556vw] py-[8vw] lg:py-[3.5vw]"
  x-data="{ open: {{ section.settings.default_open_index | json }} }"
>
  <div class="max-w-[88.889vw] mx-auto">
    {%- for block in section.blocks -%}
      {%- assign idx = forloop.index -%}
      {%- assign heading = block.settings.heading -%}

      {%- comment -%} Resolve content: metafield wins if set, else richtext setting {%- endcomment -%}
      {%- assign content_html = block.settings.content -%}
      {%- assign mf_ns = block.settings.metafield_namespace -%}
      {%- assign mf_key = block.settings.metafield_key -%}
      {%- if mf_ns != blank and mf_key != blank and product.metafields[mf_ns][mf_key] != blank -%}
        {%- assign content_html = product.metafields[mf_ns][mf_key] -%}
      {%- endif -%}

      <div
        class="accordion-row border-t border-black/15 {% if forloop.last %}border-b{% endif %}"
        {{ block.shopify_attributes }}
      >
        <button
          type="button"
          @click="open === {{ idx }} ? open = null : open = {{ idx }}"
          :aria-expanded="open === {{ idx }}"
          aria-controls="accordion-panel-{{ section.id }}-{{ idx }}"
          class="w-full flex items-center justify-between text-left py-[5vw] lg:py-[1.667vw] text-[2.8vw] lg:text-[0.833vw] tracking-[0.18em] uppercase text-[#111111] font-medium"
        >
          <span>{{ heading }}</span>
          <span class="relative w-[3.5vw] h-[3.5vw] lg:w-[1vw] lg:h-[1vw] flex-shrink-0">
            {%- comment -%} Plus → Minus morph {%- endcomment -%}
            <span class="absolute inset-0 flex items-center justify-center">
              <span class="block w-full h-px bg-[#111111]"></span>
            </span>
            <span
              class="absolute inset-0 flex items-center justify-center transition-transform duration-300"
              :class="open === {{ idx }} ? 'rotate-90 opacity-0' : 'rotate-0 opacity-100'"
            >
              <span class="block h-full w-px bg-[#111111]"></span>
            </span>
          </span>
        </button>

        <div
          id="accordion-panel-{{ section.id }}-{{ idx }}"
          class="grid transition-[grid-template-rows,opacity] duration-300 ease-out motion-reduce:transition-none"
          :class="open === {{ idx }} ? 'grid-rows-[1fr] opacity-100' : 'grid-rows-[0fr] opacity-0'"
          :aria-hidden="open !== {{ idx }}"
        >
          <div class="overflow-hidden min-h-0">
            <div
              class="pb-[6vw] lg:pb-[2.222vw] pr-[8vw] lg:pr-[6vw] text-[3.4vw] leading-[5vw] lg:text-[0.833vw] lg:leading-[1.25vw] text-[#222222]
                [&_p]:mb-[1em] [&_p:last-child]:mb-0
                [&_h3]:font-medium [&_h3]:mb-[0.4em] [&_h3]:text-[#111111]
                [&_h4]:font-medium [&_h4]:mb-[0.4em] [&_h4]:text-[#111111]
                [&_ul]:list-none [&_ul]:p-0 [&_ul]:mb-[1em]
                [&_li]:relative [&_li]:pl-[1em] [&_li]:mb-[0.25em]
                [&_li]:before:content-['·'] [&_li]:before:absolute [&_li]:before:left-0
                [&_a]:text-[#111111] [&_a]:underline [&_a]:underline-offset-2"
            >
              {%- if content_html != blank -%}
                {{ content_html }}
              {%- else -%}
                <p class="text-[#83868E]">{{ 'general.accordions.empty' | t | default: 'No content yet.' }}</p>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Product accordions",
  "tag": "section",
  "settings": [
    {
      "type": "number",
      "id": "default_open_index",
      "label": "Default open accordion (1-based, blank for none)"
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Description"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "info": "Used when no metafield is set."
        },
        {
          "type": "header",
          "content": "Metafield (optional)"
        },
        {
          "type": "text",
          "id": "metafield_namespace",
          "label": "Metafield namespace",
          "info": "Example: custom"
        },
        {
          "type": "text",
          "id": "metafield_key",
          "label": "Metafield key",
          "info": "Example: shipping_returns. When set and the product has this metafield, it overrides the Content field."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product accordions",
      "blocks": [
        {
          "type": "accordion",
          "settings": {
            "heading": "Description",
            "metafield_namespace": "custom",
            "metafield_key": "description"
          }
        },
        {
          "type": "accordion",
          "settings": {
            "heading": "Shipping & returns",
            "metafield_namespace": "custom",
            "metafield_key": "shipping_returns"
          }
        },
        {
          "type": "accordion",
          "settings": {
            "heading": "Reviews",
            "metafield_namespace": "custom",
            "metafield_key": "reviews"
          }
        },
        {
          "type": "accordion",
          "settings": {
            "heading": "FAQs",
            "metafield_namespace": "custom",
            "metafield_key": "faqs"
          }
        }
      ]
    }
  ]
}
{% endschema %}
