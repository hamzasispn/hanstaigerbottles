<div class="pt-[5.556vw] flex items-end justify-between max-w-[88.889vw] mx-auto">
  <div class="w-[35%]">
    <p data-anim="fade-up" class="text-black text-[1.389vw] leading-[1.667vw] mb-[1.667vw]">
      {{ section.settings.description }}
    </p>
    <a
      href="{{ section.settings.link }}"
      data-anim="fade-up"
      class="text-[#222222] uppercase text-[0.694vw] leading-[0.694vw] flex items-center gap-[1.111vw]"
    >
      view more
      <span class="w-[0.833vw] h-[0.833vw]">
        {% render 'black-arrow-icon' %}
      </span>
    </a>
  </div>
  <div class="w-[65%]">
    {% render 'text-box', secondTextline: section.settings.second_text, blocks: section.blocks %}
  </div>
</div>

{% schema %}
{
  "name": "Custom Text Box",
  "settings": [
    {
        "type": "textarea",
        "id": "description",
        "label": "Description"
    },
    {
        "type": "url",
        "id": "link",
        "label": "Url"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "feature_text",
          "label": "Feature Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Text Box",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "feature_text": "Engineering"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "Durability"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "BPA-Free Lid"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "Performance"
          }
        }
      ]
    }
  ]
}
{% endschema %}
