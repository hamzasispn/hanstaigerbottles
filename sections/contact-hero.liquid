<section class="contact-hero max-w-[92vw] lg:max-w-[88.889vw] mx-auto py-[12vw] lg:py-[5.556vw]">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-[8vw] lg:gap-[5.556vw]">
    {%- comment -%} Left - Text content {%- endcomment -%}
    <div class="flex flex-col justify-center order-2 lg:order-1 lg:pr-[4vw]">
      {% if section.settings.heading != blank %}
        <h1
          data-anim="split-words"
          class="text-[12vw] leading-[12vw] lg:text-[5vw] lg:leading-[5.5vw] font-normal text-black mb-[6vw] lg:mb-[2.222vw]"
        >
          {{ section.settings.heading }}
        </h1>
      {% endif %}

      {% if section.settings.description != blank %}
        <p
          data-anim="fade-up"
          class="text-[3.4vw] leading-[5vw] lg:text-[0.972vw] lg:leading-[1.528vw] text-black max-w-full lg:max-w-[26vw] mb-[4vw] lg:mb-[1.667vw]"
        >
          {{ section.settings.description }}
        </p>
      {% endif %}

      {% if section.settings.description_secondary != blank %}
        <p
          data-anim="fade-up"
          class="text-[3.4vw] leading-[5vw] lg:text-[0.972vw] lg:leading-[1.528vw] text-black max-w-full lg:max-w-[26vw] mb-[6vw] lg:mb-[2.778vw]"
        >
          {{ section.settings.description_secondary }}
        </p>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          data-anim="fade-up"
          class="inline-flex items-center gap-[2.5vw] lg:gap-[0.833vw] bg-[#E9E9E9] hover:bg-[#dcdcdc] transition-colors text-black text-[3vw] lg:text-[0.833vw] px-[5vw] lg:px-[1.389vw] py-[3vw] lg:py-[0.833vw] w-fit"
        >
          {{ section.settings.button_label }}
          <span class="w-[3.5vw] h-[3vw] lg:w-[0.972vw] lg:h-[0.833vw] inline-flex items-center">
            {% render 'button-arrow' %}
          </span>
        </a>
      {% endif %}
    </div>

    {%- comment -%} Right - Stacked images {%- endcomment -%}
    <div class="flex flex-col gap-[3vw] lg:gap-[1.111vw] order-1 lg:order-2">
      {% if section.settings.top_image != blank %}
        <img
          src="{{ section.settings.top_image | image_url: width: 1400 }}"
          alt="{{ section.settings.top_image.alt | escape }}"
          width="1400"
          height="700"
          class="w-full h-[55vw] lg:h-[20vw] object-cover"
          loading="eager"
        >
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'w-full h-[55vw] lg:h-[20vw] object-cover bg-gray-200' }}
      {% endif %}

      {% if section.settings.bottom_image != blank %}
        <img
          src="{{ section.settings.bottom_image | image_url: width: 1400 }}"
          alt="{{ section.settings.bottom_image.alt | escape }}"
          width="1400"
          height="900"
          class="w-full h-[90vw] lg:h-[28vw] object-cover"
          loading="lazy"
        >
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'w-full h-[90vw] lg:h-[28vw] object-cover bg-gray-200' }}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Hero",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Let's talk."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Whether you have a question, a project in mind or simply want to know more about what we do, we are here."
    },
    {
      "type": "textarea",
      "id": "description_secondary",
      "label": "Secondary Description",
      "default": "Reach out and one of our team members will get back to you with the care and attention your enquiry deserves."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Get in touch"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "top_image",
      "label": "Top Image"
    },
    {
      "type": "image_picker",
      "id": "bottom_image",
      "label": "Bottom Image"
    }
  ],
  "presets": [
    {
      "name": "Contact Hero"
    }
  ]
}
{% endschema %}
