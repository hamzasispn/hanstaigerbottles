<div class="py-[10vw] lg:py-[4.167vw] overflow-hidden px-[5.556vw]">

  <div class="swiper marquee-swiper-{{ section.id }}">
    <div class="swiper-wrapper items-center">
      {% for block in section.blocks %}
        {% if block.type == 'logo' %}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <div class="flex items-center justify-center px-[6vw] lg:px-[2.778vw]">
              {% if block.settings.logo != blank %}
                <img
                  src="{{ block.settings.logo | image_url: width: 300 }}"
                  alt="{{ block.settings.logo.alt | escape | default: 'Client Logo' }}"
                  class="h-[8vw] lg:h-[2.778vw] w-auto object-contain {% if section.settings.grayscale %}grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300{% endif %}"
                  width="300"
                  height="100"
                >
              {% else %}
                <div class="h-[8vw] lg:h-[2.778vw] w-[20vw] lg:w-[8.333vw] bg-gray-200 rounded flex items-center justify-center">
                  <span class="text-[3vw] lg:text-[0.833vw] text-gray-400">Logo</span>
                </div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.marquee-swiper-{{ section.id }}', {
      loop: true,
      slidesPerView: 4,
      spaceBetween: 160,
      speed: {{ section.settings.speed }},
      autoplay: {
        delay: 0,
        disableOnInteraction: false,
        pauseOnMouseEnter: {{ section.settings.pause_on_hover }},
      },
      allowTouchMove: true,
      freeMode: {
        enabled: true,
        momentum: false,
      },
    });
  });
</script>

{% schema %}
{
  "name": "Marquee Logos",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed",
      "min": 2000,
      "max": 9900,
      "step": 100,
      "default": 4000,
      "info": "Lower = faster"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on Hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "grayscale",
      "label": "Grayscale Logos",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Logos",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}