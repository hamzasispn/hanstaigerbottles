<div class="mx-auto max-w-[92vw] lg:max-w-[88.889vw]">
  {% if section.settings.heading != blank %}
    <h2
      data-anim="split-words"
      class="font-light text-[#111111] leading-[1.05] tracking-[-0.02em] text-[12vw] max-w-full lg:text-[5.56vw] lg:max-w-[30vw] lg:mt-[12.847vw] mb-[8vw] lg:mb-[9.444vw] "
    >
      {{ section.settings.heading }}
    </h2>
  {% endif %}

  {%- comment -%} Image Grid {%- endcomment -%}
  {%- assign image_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'image-card' and block.settings.img != blank -%}
      {%- assign image_count = image_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}

  <div
    class="grid gap-[3vw] py-[12vw] lg:gap-[1.111vw] lg:py-[5.556vw]"
    x-data
    x-init="$el.style.gridTemplateColumns = window.innerWidth >= 1024 ? 'repeat({{ image_count }}, 1fr)' : 'repeat(2, 1fr)'"
    @resize.window="$el.style.gridTemplateColumns = window.innerWidth >= 1024 ? 'repeat({{ image_count }}, 1fr)' : 'repeat(2, 1fr)'"
  >
    {%- assign img_index = 0 -%}
    {% for block in section.blocks %}
      {% if block.type == 'image-card' %}
        {% if block.settings.img != blank %}
          {%- assign img_index = img_index | plus: 1 -%}
          {%- assign padded_index = img_index | prepend: '00' | slice: -2, 2 -%}
          {% if block.settings.show_content %}
            <div class="relative w-full h-full" {{ block.shopify_attributes }}>
              <img
                src="{{ block.settings.img | image_url: width: 1080 }}"
                alt="{{ block.settings.img.alt | escape }}"
                class="w-full h-full object-cover"
                width="1080"
                height="1080"
              >
              <div class="absolute inset-0 flex flex-col items-center justify-center text-center text-white p-[6vw] lg:p-[2.222vw]">
                <p class="text-[3.5vw] leading-[4vw] lg:text-[1.111vw] lg:leading-[1.389vw] tracking-[0.1em]">
                  <span style="color:{{ section.settings.brackets_color }};">[</span>
                  {{ padded_index }}
                  <span style="color:{{ section.settings.brackets_color }};">]</span>
                </p>
                <div class="mt-auto flex flex-col items-center">
                  {% if block.settings.title != blank %}
                    <h3 class="font-light text-[7vw] leading-[1.1] lg:text-[2.222vw] mb-[3vw] lg:mb-[1.111vw]">
                      {{ block.settings.title }}
                    </h3>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <p class="text-[3.5vw] leading-[5vw] lg:text-[1vw] lg:leading-[1.389vw] mb-[5vw] lg:mb-[1.667vw] max-w-[80%]">
                      {{ block.settings.description }}
                    </p>
                  {% endif %}
                  {% if block.settings.button_text != blank %}
                    <a href="{{ block.settings.button_link | default: '#' }}" class="py-[2vw] px-[3vw] gap-[3vw] text-[3vw] leading-[4vw] lg:py-[0.556vw] lg:px-[0.833vw] lg:gap-[1.111vw] lg:text-[0.972vw] lg:leading-[1.389vw] flex items-center text-white bg-[#C4C4C4]/40 backdrop-blur-md">
                      {{ block.settings.button_text }}
                      <span class="w-[4vw] h-[4vw] lg:w-[1.25vw] lg:h-[1.25vw] flex items-center justify-center">{% render 'button-arrow' %}</span>
                    </a>
                  {% endif %}
                </div>
              </div>
            </div>
          {% else %}
            <img
              src="{{ block.settings.img | image_url: width: 1080 }}"
              alt="{{ block.settings.img.alt | escape }}"
              class="w-full h-full object-cover"
              width="1080"
              height="1080"
              {{ block.shopify_attributes }}
            >
          {% endif %}
        {% endif %}
      {% endif %}
    {% endfor %}
  </div>

  {%- comment -%} Detail Lists {%- endcomment -%}
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-[6vw] lg:gap-0 pb-[10vw] lg:pb-[3.75vw] items-start">
    <div class="lg:col-span-4">
      <p class="text-[3vw] leading-[4vw] lg:text-[0.903vw] lg:leading-[1.181vw] text-black">
        {{ section.settings.subtitle }}
      </p>
    </div>

    <div class="lg:col-span-8 flex flex-wrap lg:flex-nowrap items-start gap-[6vw] lg:gap-[1.111vw]">
      {% assign detail_index = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'detail-list' %}
          {% assign detail_index = detail_index | plus: 1 %}
          <div class="w-[40vw] lg:w-[8.75vw]" {{ block.shopify_attributes }}>
            <h3 class="mb-[5vw] text-[4vw] leading-[5.4vw] px-[1vw] lg:mb-[1.736vw] lg:text-[1.111vw] lg:leading-[1.528vw] lg:px-[0.347vw] text-black font-medium">
              <span style="color:{{ section.settings.brackets_color }};">[</span> {{ block.settings.heading -}}
              <sup>{{ detail_index }}</sup> <span style="color:{{ section.settings.brackets_color }};">]</span>
            </h3>
            {% if block.settings.list != blank %}
              <div class="text-[3vw] leading-[4vw] lg:text-[0.833vw] lg:leading-[1.111vw] text-black">
                {{ block.settings.list }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Gallery Section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sub title",
      "default": "How we do it"
    },
    {
      "type": "color",
      "id": "brackets_color",
      "label": "Brackets Color",
      "default": "#E53D00"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "image-card",
      "name": "Image Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "img",
          "label": "Upload Image"
        },
        {
          "type": "checkbox",
          "id": "show_content",
          "label": "Show Content",
          "default": false
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "visible_if": "{{ block.settings.show_content }}"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "visible_if": "{{ block.settings.show_content }}"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "visible_if": "{{ block.settings.show_content }}"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link",
          "visible_if": "{{ block.settings.show_content }}"
        }
      ]
    },
    {
      "type": "detail-list",
      "name": "Details List",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "list",
          "label": "List"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gallery Section",
      "blocks": [
        { "type": "image-card" },
        { "type": "image-card" },
        { "type": "image-card" },
        { "type": "detail-list", "settings": { "heading": "Materials" } },
        { "type": "detail-list", "settings": { "heading": "Process" } }
      ]
    }
  ]
}
{% endschema %}
