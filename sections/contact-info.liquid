<section class="contact-info pb-[12vw] lg:pb-[5.556vw]">
  <div class="max-w-[92vw] lg:max-w-[88.889vw] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-[8vw] lg:gap-[5.556vw] mb-[12vw] lg:mb-[6.944vw]">
      {%- comment -%} Left - Heading {%- endcomment -%}
      <div>
        {% if section.settings.heading != blank %}
          <h2
            data-anim="fade-up"
            class="text-[6vw] leading-[7vw] lg:text-[2.222vw] lg:leading-[2.778vw] font-normal text-black"
          >
            {{ section.settings.heading }}
          </h2>
        {% endif %}
      </div>

      {%- comment -%} Right - Contact list {%- endcomment -%}
      <div data-anim="stagger-children" class="flex flex-col gap-[7vw] lg:gap-[2.778vw]">
        {% for block in section.blocks %}
          {% if block.type == 'contact_item' %}
            <div
              class="flex flex-col gap-[1.5vw] lg:gap-[0.556vw]"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.label != blank %}
                <span class="text-[2.6vw] leading-[2.6vw] lg:text-[0.694vw] lg:leading-[0.694vw] uppercase text-[#83868E] tracking-[0.15vw] lg:tracking-[0.05vw]">
                  {{ block.settings.label }}
                </span>
              {% endif %}
              {% if block.settings.value != blank %}
                {% if block.settings.link != blank %}
                  <a
                    href="{{ block.settings.link }}"
                    class="text-[5vw] leading-[6vw] lg:text-[1.667vw] lg:leading-[2vw] text-black hover:opacity-70 transition-opacity"
                  >
                    {{ block.settings.value }}
                  </a>
                {% else %}
                  <span class="text-[5vw] leading-[6vw] lg:text-[1.667vw] lg:leading-[2vw] text-black">
                    {{ block.settings.value }}
                  </span>
                {% endif %}
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  {%- comment -%} Featured image (full-width band) {%- endcomment -%}
  {% if section.settings.featured_image != blank %}
    <div class="max-w-[92vw] lg:max-w-[63.889vw] mx-auto">
      <img
        src="{{ section.settings.featured_image | image_url: width: 2000 }}"
        alt="{{ section.settings.featured_image.alt | escape }}"
        width="2000"
        height="1000"
        class="w-full h-[60vw] lg:h-[28vw] object-cover"
        loading="lazy"
      >
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Contact Info",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Prefer to contact us differently?"
    },
    {
      "type": "header",
      "content": "Featured Image"
    },
    {
      "type": "image_picker",
      "id": "featured_image",
      "label": "Image"
    }
  ],
  "blocks": [
    {
      "type": "contact_item",
      "name": "Contact Item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Email"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "info@hanstaiger.com"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)",
          "info": "Use mailto: or tel: prefix when applicable."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact Info",
      "blocks": [
        {
          "type": "contact_item",
          "settings": {
            "label": "Email",
            "value": "info@hanstaiger.com"
          }
        },
        {
          "type": "contact_item",
          "settings": {
            "label": "Sales team",
            "value": "+34 999 99 99"
          }
        },
        {
          "type": "contact_item",
          "settings": {
            "label": "New projects",
            "value": "+34 999 99 99"
          }
        },
        {
          "type": "contact_item",
          "settings": {
            "label": "Chartering enquiries",
            "value": "+34 999 99 99"
          }
        },
        {
          "type": "contact_item",
          "settings": {
            "label": "Hanstaiger X1 lab",
            "value": "+34 999 99 99"
          }
        }
      ]
    }
  ]
}
{% endschema %}
