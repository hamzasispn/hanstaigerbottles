      "id": "right_image_fit",
      "label": "Right Image Fit",
      "options": [
        { "value": "cover", "label": "Cover (fill & crop)" },
        { "value": "contain", "label": "Contain (show full image)" }
      ],
      "default": "cover"
    },
    {
      "type": "text",
      "id": "right_heading",
