<div class="image-box py-[6.944vw] px-[5.556vw]">
  <div
    class="h-screen py-[6.944vw] px-[6.25vw] flex flex-col justify-between relative z-10 bg-[#dfe0e2] rounded-sm overflow-hidden"
  >
    {%- comment -%} Background Image {%- endcomment -%}
    {% if section.settings.background_image %}
      <img
        src="{{ section.settings.background_image | img_url: '2000x' }}"
        width="2000"
        height="1000"
        alt="{{ section.settings.background_image.alt | escape }}"
        class="absolute inset-0 w-full h-full -z-10"
        style="object-fit: {{ section.settings.image_fit }};"
      >
    {% else %}
      <img
        src="{{ 'image-box-bg.jpg' | asset_url }}"
        width="2000"
        height="1000"
        alt=""
        class="absolute inset-0 w-full h-full -z-10"
        style="object-fit: {{ section.settings.image_fit }};"
      >
    {% endif %}

    {%- comment -%} Feature List — top right {%- endcomment -%}
    <div class="w-full flex justify-end">
      {% if section.blocks.size > 0 %}
        <ul data-anim="stagger-children">
          {% for block in section.blocks %}
            {% if block.type == 'feature_item' %}
              <li
                class="text-[0.972vw] leading-[1.389vw] flex items-center gap-[1.111vw] mb-[1.389vw]"
                {{ block.shopify_attributes }}
              >
                <span class="w-[1.667vw] h-[1.667vw] p-[0.347vw]">
                  {% if block.settings.icon == 'calender-icon' %}
                    {% render 'calender-icon' %}
                  {% elsif block.settings.icon == 'globe-icon' %}
                    {% render 'globe-icon' %}
                  {% elsif block.settings.icon == 'replay-music-icon' %}
                    {% render 'replay-music-icon' %}
                  {% else %}
                    {% render 'calender-icon' %}
                  {% endif %}
                </span>
                <div>
                  {% if block.settings.label != blank %}
                    <span class="text-[#4F5257] mr-[0.833vw] inline-block">{{ block.settings.label }}</span>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <span class="text-[#83868E]">{{ block.settings.description }}</span>
                  {% endif %}
                </div>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      {% endif %}
    </div>

    {%- comment -%} Bottom Content {%- endcomment -%}
    <div class="w-full">
      {% if section.settings.heading != blank %}
        <h2
          data-anim="split-words"
          class="text-[1.889vw] mb-[0.556vw]"
          style="
            color: {{ section.settings.heading_color }};
            font-family: '{{ section.settings.font_family }}', sans-serif;
          "
        >
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p data-anim="fade-up" class="text-[0.813vw] uppercase tracking-[0.09vw] text-[#83868E] mb-[1.389vw]">
          {{ section.settings.subheading }}
        </p>
      {% endif %}

      {% if section.settings.description != blank %}
        <p
          data-anim="fade-up"
          class="text-[1.111vw] leading-[1.528vw] mb-[2.778vw] max-w-[30.069vw]"
          style="
            color: {{ section.settings.description_color }};
            font-family: '{{ section.settings.font_family }}', sans-serif;
          "
        >
          {{ section.settings.description }}
        </p>
      {% endif %}

      {% if section.settings.button_url != blank %}
        <a
          href="{{ section.settings.button_url }}"
          class="{% if section.settings.button_label == blank %} w-[6.944vw] {% endif%} h-[2.5vw] px-[1.111vw] inline-flex items-center justify-center gap-[0.556vw] text-[0.833vw] font-medium"
          style="
            background-color: {{ section.settings.button_bg_color }};
            color: {{ section.settings.button_text_color }};
            font-family: '{{ section.settings.font_family }}', sans-serif;
          "
        >
          {% if section.settings.button_label != blank %}
            <span>{{ section.settings.button_label }}</span>
          {% endif %}
          {% render 'button-arrow' %}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image Box",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image Fit",
      "options": [
        { "value": "cover", "label": "Cover (fill & crop)" },
        { "value": "contain", "label": "Contain (show full image)" }
      ],
      "default": "cover"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Automated replenishment"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#4F5257"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "SUBSCRIBE TO ELECTROLYTES"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Receive a fresh 30-day supply of X1 Electrolytes every month, delivered directly to your door. Subscribe or cancel anytime. No commitments, no complexity. Currently available across Europe only."
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description Color",
      "default": "#83868E"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Text",
      "default": "Shop now"
    },
    {
      "type": "color_background",
      "id": "button_bg_color",
      "label": "Button Background Color",
      "default": "rgba(209, 209, 209, 1)"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font Family",
      "options": [
        { "value": "Inter", "label": "Inter" },
        { "value": "Helvetica Neue", "label": "Theme Default" },
        { "value": "Georgia", "label": "Georgia" },
        { "value": "Playfair Display", "label": "Playfair Display" },
        { "value": "DM Sans", "label": "DM Sans" },
        { "value": "Montserrat", "label": "Montserrat" },
        { "value": "Lato", "label": "Lato" }
      ],
      "default": "Inter"
    }
  ],
  "blocks": [
    {
      "type": "feature_item",
      "name": "Feature Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "calender-icon", "label": "Calendar" },
            { "value": "globe-icon", "label": "Globe" },
            { "value": "replay-music-icon", "label": "Replay" }
          ],
          "default": "calender-icon"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Feature Label"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Short description of the feature."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Box",
      "blocks": [
        {
          "type": "feature_item",
          "settings": {
            "icon": "calender-icon",
            "label": "30-Day Cycle",
            "description": "Perfectly timed for continuous use."
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "icon": "globe-icon",
            "label": "Full Control",
            "description": "Pause, skip, or cancel from your account."
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "icon": "replay-music-icon",
            "label": "Europe Only",
            "description": "Reliable delivery across all EU countries."
          }
        }
      ]
    }
  ]
}
{% endschema %}
