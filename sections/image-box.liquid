<div class="image-box py-[6.944vw] px-[5.556vw]">
  <div class="h-screen py-[6.944vw] px-[6.25vw] flex flex-col justify-between relative z-10 bg-[#dfe0e2] rounded-sm">
    {% if section.settings.background_image %}
      <img
        src="{{ section.settings.background_image | img_url: '1000x1000' }}"
        width="1000"
        height="1000"
        class="absolute top-1/2 transform -translate-1/2 left-1/2 -z-10 object-contain"
        alt="{{ section.settings.background_image.alt | escape }}"
      >
    {% else %}
      <img
        src="{{ 'image-box-bg.jpg' | asset_url }}"
        width="1000"
        height="1000"
        class="absolute top-1/2 transform -translate-1/2 left-1/2 -z-10 object-contain"
        alt=""
      >
    {% endif %}

    <div class="w-full flex justify-end">
      {% if section.blocks.size > 0 %}
        <ul>
          {% for block in section.blocks %}
            {% if block.type == 'feature_item' %}
              <li class="text-[0.972vw] leading-[1.389vw] flex items-center gap-[1.111vw] mb-[1.389vw]" {{ block.shopify_attributes }}>
                <span class="w-[1.667vw] h-[1.667vw] p-[0.347vw]">
                  {% if block.settings.icon == "calender-icon" %}
                    {% render 'calender-icon' %}
                  {% elsif block.settings.icon == "globe-icon" %}
                    {% render 'globe-icon' %}
                  {% elsif block.settings.icon == "replay-music-icon" %}
                    {% render 'replay-music-icon' %}
                  {% else %}
                    {% render 'calender-icon' %}
                  {% endif %}
                </span>
                <div>
                  {% if block.settings.label != blank %}
                    <span class="text-[#4F5257] mr-[0.833vw] inline-block">{{ block.settings.label }}</span>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <span class="text-[#83868E]">{{ block.settings.description }}</span>
                  {% endif %}
                </div>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      {% endif %}
    </div>

    <div class="w-full">
      {% if section.settings.heading != blank %}
        <h2 class="text-[1.889vw] mb-[0.556vw] text-[#4F5257]">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="text-[0.813vw] uppercase tracking-[0.09vw] text-[#83868E] mb-[1.389vw]">{{ section.settings.subheading }}</p>
      {% endif %}

      {% if section.settings.description != blank %}
        <p class="text-[1.111vw] leading-[1.528vw] mb-[2.778vw] max-w-[30.069vw] text-[#83868E]">
          {{ section.settings.description }}
        </p>
      {% endif %}

      {% if section.settings.button_url != blank %}
        <a href="{{ section.settings.button_url }}" class="bg-[#D1D1D1] h-[2.5vw] w-[6.944vw] flex items-center justify-center">
          {% render 'button-arrow' %}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image Box",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Automated replenishment"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "SUSCRIBE TO ELECTROLYTES"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Receive a fresh 30-day supply of X1 Electrolytes every month, delivered directly to your door. Subscribe or cancel anytime. No commitments, no complexity. Currently available across Europe only."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button Link",
      "default": "/"
    }
  ],
  "blocks": [
    {
      "type": "feature_item",
      "name": "Feature Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "calender-icon", "label": "Calendar" },
            { "value": "globe-icon", "label": "Globe" },
            { "value": "replay-music-icon", "label": "Replay" }
          ],
          "default": "calender-icon"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Feature Label"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Short description of the feature."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Box",
      "blocks": [
        {
          "type": "feature_item",
          "settings": {
            "icon": "calender-icon",
            "label": "30-Day Cycle",
            "description": "Perfectly timed for continuous use."
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "icon": "globe-icon",
            "label": "Full Control",
            "description": "Pause, skip, or cancel from your account."
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "icon": "replay-music-icon",
            "label": "Europe Only",
            "description": "Reliable delivery across all EU countries."
          }
        }
      ]
    }
  ]
}
{% endschema %}
