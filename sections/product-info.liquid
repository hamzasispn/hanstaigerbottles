<div class="pt-[20vw] lg:pt-[10vw] product-info-section" id="product-info-{{ section.id }}">
  <div class="flex flex-col items-center">
    <div class="mb-[3vw] lg:mb-[1.528vw]">
      {% render 'x1-icon' %}
    </div>
    <span class="text-black text-[2.8vw] leading-[4vw] lg:text-[0.972vw] lg:leading-[1.389vw]"> From the X1</span>
    <div class="h-[109.474vw] lg:h-[25.417vw] w-full relative">
      <div class="w-full h-full flex flex-col items-center justify-center absolute bottom-0 left-1/2 transform -translate-x-1/2">
        <h2
          id="pi-heading-left-{{ section.id }}"
          class="font-normal lg:font-light text-(--color-primary) text-center text-[18.947vw] leading-[23.158vw] -tracking-[0.105vw] lg:text-[8.333vw] lg:leading-[7.5vw]"
        >
          {{ section.settings.product_info_title_first_line }}
        </h2>
        <h2
          id="pi-heading-right-{{ section.id }}"
          class="font-normal lg:font-light text-(--color-primary) text-center text-[18.947vw] leading-[23.158vw] lg:text-[8.333vw] lg:leading-[7.5vw]"
        >
          {{ section.settings.product_info_title_second_line }}
        </h2>
      </div>
      <img
        id="pi-bottle-{{ section.id }}"
        width="400"
        height="400"
        src="{% if section.settings.product_info_image %}{{ section.settings.product_info_image | img_url: 'master' }}{% else %}{{ 'x1-product.png' | asset_url }}{% endif %}"
        alt="Hanstaiger X1 Bottle"
        class="w-[53.421vw] h-[75.526vw] lg:w-[38.056vw] lg:h-[24.931vw] block object-contain absolute -bottom-[8vw] lg:-bottom-[4vw] left-1/2 transform -translate-x-1/2 z-10"
      >
    </div>
  </div>
  <div class="pt-[18vw] lg:pt-[15.139vw] flex flex-col lg:flex-row items-start lg:items-end justify-between gap-[6vw] lg:gap-0 max-w-[88vw] lg:max-w-[58.889vw] mx-auto">
    <div class="w-full lg:w-[35%]">
      <p data-anim="fade-up" class="text-[#83868E] text-[3.6vw] leading-[5vw] mb-[5vw] lg:text-[1.111vw] lg:leading-[1.528vw] lg:mb-[2.5vw]">
        {{ section.settings.product_info_text }}
      </p>
      <p data-anim="fade-up" class="text-[#222222] font-medium text-[3.6vw] leading-[5vw] lg:text-[1.111vw] lg:leading-[1.528vw]">
        For those who don’t settle for standard.
      </p>
    </div>
    <div class="w-full lg:w-[65%]">
      <p data-anim="fade-up" class="text-[#222222] font-medium text-[2.8vw] leading-[3.6vw] lg:text-[0.903vw] lg:leading-[1.181vw] text-right">
        {{ section.settings.second_text }}
      </p>
      <ul data-anim="stagger-children" class="flex gap-[1.5vw] lg:gap-[0.417vw] flex-wrap justify-end mt-[3vw] lg:mt-[1.667vw]">
        {% for block in section.blocks %}
          {% render 'text-box', block: block %}
        {% endfor %}
      </ul>
    </div>
  </div>
</div>

<script>
  (function () {
    var suffix = '{{ section.id }}';
    var bottle = document.getElementById('pi-bottle-' + suffix);
    var headLeft = document.getElementById('pi-heading-left-' + suffix);
    var headRight = document.getElementById('pi-heading-right-' + suffix);
    var section = document.getElementById('product-info-' + suffix);

    if (!bottle || !headLeft || !headRight || !section) return;

    // theme.js (defer) exposes window.gsap + window.ScrollTrigger — wait for it
    function setup() {
      if (!window.gsap || !window.ScrollTrigger) {
        setTimeout(setup, 50);
        return;
      }

      var tl = window.gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top 90%',
          end: 'top 10%',
          scrub: 1.2,
        },
      });

      tl.fromTo(bottle, { y: 160, opacity: 0 }, { y: 0, opacity: 1, ease: 'none' }, 0)
        .fromTo(headLeft, { x: -180, opacity: 0 }, { x: 0, opacity: 1, ease: 'none' }, 0)
        .fromTo(headRight, { x: 180, opacity: 0 }, { x: 0, opacity: 1, ease: 'none' }, 0);
    }

    setup();
  })();
</script>

{% schema %}
{
  "name": "Product Info",
  "settings": [
    {
      "type": "text",
      "id": "product_info_title_first_line",
      "label": "Product Info Title - First Line",
      "default": "Developed"
    },
    {
      "type": "text",
      "id": "product_info_title_second_line",
      "label": "Product Info Title - Second Line",
      "default": "to endure"
    },
    {
      "type": "text",
      "id": "product_info_text",
      "label": "Product Info Text",
      "default": "Every product in Hanstaiger World was tested aboard the X1 trimaran during extended voyages across the Mediterranean and Atlantic."
    },
    {
      "type": "image_picker",
      "id": "product_info_image",
      "label": "Product Info Image"
    },
    {
      "type": "text",
      "id": "second_text",
      "label": "Second Text Line",
      "default": "Born onboard, evolved beyond"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "feature_text",
          "label": "Feature Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Info",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "feature_text": "Engineering"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "Durability"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "BPA-Free Lid"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "Performance"
          }
        }
      ]
    }
  ]
}
{% endschema %}
