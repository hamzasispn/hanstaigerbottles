{% comment %}
  Hanstaiger World Footer
  Requirements: Tailwind CSS + Alpine.js loaded in theme layout
{% endcomment %}

<footer class="bg-[#ebebeb] w-full font-(--font-primary--family)" x-data="{ open: false }">
  <div class="max-w-[88.889vw] mx-auto px-6 lg:px-16 pt-14 pb-8">

    <div class="mb-12">
      <a href="{{ routes.root_url }}" class="text-[#3a3a3a] text-sm tracking-[0.25em] uppercase font-normal">
        Hanstaiger World
      </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-6 mb-16 items-center justify-between">

      <div class="flex flex-col gap-2 col-span-1">
        <a href="{{ routes.root_url }}"
           class="text-[#3a3a3a] text-base hover:opacity-60 transition-opacity duration-200 w-fit">
          Home
        </a>
        <a href="{{ routes.collections_url }}/bottles"
           class="text-[#3a3a3a] text-base hover:opacity-60 transition-opacity duration-200 w-fit">
          Bottles
        </a>
        <a href="{{ routes.collections_url }}/electrolytes"
           class="text-[#3a3a3a] text-base hover:opacity-60 transition-opacity duration-200 w-fit">
          Electrolytes
        </a>
        <a href="{{ routes.collections_url }}/gear"
           class="text-[#3a3a3a] text-base hover:opacity-60 transition-opacity duration-200 w-fit">
          Gear
        </a>
        <a href="{{ routes.collections_url }}/the-x1"
           class="text-[#3a3a3a] text-base hover:opacity-60 transition-opacity duration-200 w-fit">
          The X1
        </a>
        <a href="/pages/b2b"
           class="text-[#3a3a3a] text-base hover:opacity-60 transition-opacity duration-200 w-fit">
          B2B
        </a>
      </div>

      <div class="flex flex-col gap-2 col-span-1 h-full">
        <a href="{{ settings.social_linkedin_link }}"
           target="_blank"
           rel="noopener noreferrer"
           class="text-[#3a3a3a] text-base hover:opacity-60 transition-opacity duration-200 flex items-center gap-[0.833vw] w-fit">
          LinkedIn
          <span class="text-xs leading-none translate-y-[-1px] w-[1.111vw] h-[1.111vw]">{% render 'link-icon' %}</span>
        </a>
        <a href="{{ settings.social_instagram_link }}"
           target="_blank"
           rel="noopener noreferrer"
           class="text-[#3a3a3a] text-base hover:opacity-60 transition-opacity duration-200 flex items-center gap-[0.833vw] w-fit">
          Instagram
          <span class="text-xs leading-none translate-y-[-1px] w-[1.111vw] h-[1.111vw]">{% render 'link-icon' %}</span>
        </a>
        <a href="{{ settings.social_twitter_link }}"
           target="_blank"
           rel="noopener noreferrer"
           class="text-[#3a3a3a] text-base hover:opacity-60 transition-opacity duration-200 flex items-center gap-[0.833vw] w-fit">
          X
          <span class="text-xs leading-none translate-y-[-1px] w-[1.111vw] h-[1.111vw]">{% render 'link-icon' %}</span>
        </a>
      </div>
      <div class="hidden lg:col-span-2"></div>
      <div class="bg-[#e0e0e0] rounded-sm p-[1.667vw] flex flex-col lg:flex-row items-start lg:items-center justify-between col-span-8">
        <p class="text-[#3a3a3a] text-lg leading-snug max-w-xs">
          Engineered at sea. Let's supply your journey.
        </p>
        <a href="/pages/contact"
           class="shrink-0 border border-[#b0b0b0] text-[#3a3a3a] text-sm px-6 py-3 hover:bg-[#d4d4d4] transition-colors duration-200 whitespace-nowrap">
          Contact us now
        </a>
      </div>

    </div>

    <div class="border-t border-[#d0d0d0] pt-8 flex flex-col lg:flex-row lg:items-end justify-between gap-6">

      <div class="flex flex-col gap-1">
        <div class="flex items-center gap-4">
          <span class="text-[10px] tracking-widest uppercase text-[#888] font-normal w-12">Email</span>
          <a href="mailto:{{ settings.contact_email | default: 'contact@hanstaiger.com' }}"
             class="text-[#3a3a3a] text-xs tracking-wide uppercase hover:opacity-60 transition-opacity duration-200">
            {{ settings.contact_email | default: 'contact@hanstaiger.com' }}
          </a>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-[10px] tracking-widest uppercase text-[#888] font-normal w-12">Phone</span>
          <a href="tel:{{ settings.contact_phone | default: '+15551234567' | remove: ' ' | remove: '-' | remove: '(' | remove: ')' }}"
             class="text-[#3a3a3a] text-xs tracking-wide hover:opacity-60 transition-opacity duration-200">
            {{ settings.contact_phone | default: '+1 (555) 123-4567' }}
          </a>
        </div>
      </div>

      <div class="flex items-center gap-8 lg:gap-10">
        <a href="{{ routes.root_url }}policies/privacy-policy"
           class="text-[#3a3a3a] text-xs hover:opacity-60 transition-opacity duration-200">
          Privacy
        </a>
        <a href="{{ routes.root_url }}policies/terms-of-service"
           class="text-[#3a3a3a] text-xs hover:opacity-60 transition-opacity duration-200">
          Terms
        </a>
        <a href="/pages/contact"
           class="text-[#3a3a3a] text-xs hover:opacity-60 transition-opacity duration-200">
          Contact
        </a>
      </div>

    </div>

  </div>
</footer>
