{% comment %}
  Section: product-accordion.liquid → /sections/
  Accordion card row: clicking + on a collapsed card expands it (full bleed image),
  collapses the active one. Second card open by default.
  Requires: Alpine.js, Tailwind CSS
  Product data pulled directly from product picker — no manual fields needed.
{% endcomment %}

<section
  x-data="
    {
      active: 1,
      open(i) { this.active = i; },
      isActive(i) { return this.active === i; }
    }
  "
  class="w-full bg-[#F4F4F5]"
  style="padding: 4.44vw 3.61vw 5.56vw;"
>
  <div data-anim="stagger-children" class="flex items-stretch h-[26.69vw]" style="gap: 1.11vw;">
    {%- for block in section.blocks -%}
      {%- assign i = forloop.index0 -%}
      {%- assign product = block.settings.product -%}

      {%- assign card_title = product.title | default: 'Product' -%}
      {%- assign card_image = product.featured_image -%}
      {%- assign card_price = product.price_min | money -%}
      {%- assign card_compare = product.compare_at_price_min -%}
      {%- assign card_variant = product.first_available_variant -%}
      {%- assign card_url = product.url -%}

      <div
        x-bind:style="
          isActive({{ i }})
          ? 'flex: 2; min-width: 0;'
          : 'flex: 1; min-width: 0;'
        "
        class="relative overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] rounded-[0.56vw]"
        style="flex: 1;"
        {{ block.shopify_attributes }}
      >
        {%- comment -%} ═══ EXPANDED STATE ═══ {%- endcomment -%}
        <div
          x-show="isActive({{ i }})"
          x-transition:enter="transition-opacity duration-300 delay-150"
          x-transition:enter-start="opacity-0"
          x-transition:enter-end="opacity-100"
          x-transition:leave="transition-opacity duration-150"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
          class="absolute inset-0 flex flex-col"
        >
          {%- comment -%} Background image {%- endcomment -%}
          <div class="absolute inset-0">
            {%- if card_image != blank -%}
              <img
                src="{{ card_image | image_url: width: 1400 }}"
                alt="{{ card_image.alt | escape | default: card_title }}"
                class="w-full h-full object-cover"
                loading="lazy"
              >
            {%- else -%}
              <div class="w-full h-full bg-gradient-to-br from-[#3a6070] via-[#1e3040] to-[#0a0f14]"></div>
            {%- endif -%}
            <div
              class="absolute inset-0"
              style="background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.20) 45%, rgba(0,0,0,0.75) 100%);"
            ></div>
          </div>

          {%- comment -%} Minus / close button — top right {%- endcomment -%}
          <button
            @click="active = -1"
            class="absolute z-20 flex items-center justify-center rounded-full border border-white border-opacity-50 text-white bg-black bg-opacity-20 hover:bg-opacity-35 transition-all duration-200"
            style="top: 1.11vw; right: 1.11vw; width: 1.67vw; height: 1.67vw;"
            aria-label="Close"
          >
            <svg style="width: 0.69vw; height: 0.69vw;" viewBox="0 0 12 2" fill="none">
              <line x1="0.5" y1="1" x2="11.5" y2="1" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>

          {%- comment -%} Content — pinned to bottom {%- endcomment -%}
          <div class="absolute inset-x-0 bottom-0 z-10 p-[0.833vw]">
            <div class="flex justify-between p-[1.389vw]">
              <div>
                <h3 class="font-medium text-white leading-[1.528vw] text-[1.111vw] mb-[0.694vw]">
                  {{ card_title }}
                </h3>

                {%- comment -%} Option value badges {%- endcomment -%}
                {%- if product != blank and product.options_with_values.size > 0 -%}
                  <div class="flex items-center flex-wrap gap-[0.556vw]">
                    {%- for option in product.options_with_values limit: 2 -%}
                      {%- assign first_val = option.values | first -%}
                      {%- if forloop.first -%}
                        <span class="text-[#DFE0E3] text-[0.972vw] leading-[1.389vw]">
                          {{ first_val }}
                        </span>
                      {%- else -%}
                        <span
                          class="text-white border border-white"
                          style="font-size: 0.83vw; padding: 0.14vw 0.56vw; border-radius: 0.21vw;"
                        >
                          {{ first_val }}
                        </span>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>

              <div class="flex flex-col items-end justify-end">
                <span class="font-medium text-white" style="font-size: 1.25vw;">
                  {{ card_price }}
                </span>
              </div>
            </div>

            {%- comment -%} Divider {%- endcomment -%}
            <div class="w-full bg-white bg-opacity-25 h-px mb-[1.11vw]"></div>

            {%- comment -%} Add to cart {%- endcomment -%}
            {%- if card_variant != blank -%}
              <form action="/cart/add" method="post">
                <input type="hidden" name="id" value="{{ card_variant.id }}">
                <input type="hidden" name="quantity" value="1">
                <button
                  type="submit"
                  class="flex items-center justify-center ml-auto text-[0.972vw] w-[8.958vw] bg-[#F4F4F5]/40 backdrop-blur-sm text-white px-[0.833vw] py-[0.556vw] leading-[1.389vw] gap-[1.111vw]"
                >
                  Add to cart <span>{% render 'button-arrow' %}</span>
                </button>
              </form>
            {%- else -%}
              <a
                href="{{ card_url }}"
                class="flex items-center justify-center ml-auto text-[0.972vw] w-[8.958vw] bg-[#F4F4F5]/40 backdrop-blur-sm text-white px-[0.833vw] py-[0.556vw] leading-[1.389vw] gap-[1.111vw]"
              >
                View product <span>{% render 'button-arrow' %}</span>
              </a>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} ═══ COLLAPSED STATE — matches bundle-card.liquid ═══ {%- endcomment -%}
        <div
          x-show="!isActive({{ i }})"
          x-transition:enter="transition-opacity duration-300 delay-100"
          x-transition:enter-start="opacity-0"
          x-transition:enter-end="opacity-100"
          x-transition:leave="transition-opacity duration-100"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
          class="absolute inset-0 flex flex-col bg-white p-[0.833vw]"
        >
          {%- comment -%} Top zone: image + plus button {%- endcomment -%}
          <div class="relative flex-shrink-0 mb-[3.194vw] h-[11.319vw]">
            {%- comment -%} Product image — top-left {%- endcomment -%}
            <div class="absolute top-0 left-0 overflow-hidden w-[11.319vw] h-[11.319vw] bg-[#F4F4F5] rounded-[0.187vw] p-[1vw]">
              {%- if card_image != blank -%}
                <img
                  src="{{ card_image | image_url: width: 280 }}"
                  alt="{{ card_image.alt | escape | default: card_title }}"
                  class="w-full h-full object-cover"
                  loading="lazy"
                >
              {%- else -%}
                <div class="w-full h-full bg-[#E4E4E6] flex items-center justify-center">
                  {{ 'product-1' | placeholder_svg_tag: 'w-12 h-12 opacity-30' }}
                </div>
              {%- endif -%}
            </div>

            {%- comment -%} Plus button — top-right {%- endcomment -%}
            <button
              @click="open({{ i }})"
              class="absolute top-0 right-0 flex items-center justify-center bg-white rounded-full text-[#111111] hover:bg-[#111111] hover:text-white transition-colors duration-200"
              style="width: 1.67vw; height: 1.67vw;"
              aria-label="Open {{ card_title }}"
            >
              <svg style="width: 0.69vw; height: 0.69vw;" viewBox="0 0 12 12" fill="none">
                <line x1="6" y1="0.5" x2="6" y2="11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="0.5" y1="6" x2="11.5" y2="6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </button>
          </div>

          {%- comment -%} Content — fills remaining height {%- endcomment -%}
          <div class="flex flex-col flex-1 justify-between">
            <div class="p-[1.389vw]">
              {%- comment -%} Title {%- endcomment -%}
              <div class="flex items-center justify-between gap-[1.111vw]">
                <h3 class="font-medium text-black leading-[1.528vw] text-[0.972vw] tracking-[0.014vw] mb-[0.694vw] line-clamp-1">
                  {{ card_title }}
                </h3>
                <span class="text-[#83868E] text-[0.972vw]">{{ card_price }}</span>
              </div>

              {%- comment -%} Product type as subtitle {%- endcomment -%}
              {%- if product.type != blank -%}
                <p class="text-[#83868E] text-[0.972vw] leading-[1.389vw] mb-[0.556vw] font-normal">
                  {{ product.type }}
                </p>
              {%- endif -%}

              {%- comment -%} Option value rows — dot + label, like bundle card variant rows {%- endcomment -%}
              {%- if product != blank and product.options_with_values.size > 0 -%}
                <div class="flex flex-col" style="gap: 0.42vw;">
                  {%- for option in product.options_with_values limit: 2 -%}
                    {%- assign first_val = option.values | first -%}
                    <div class="flex items-center gap-[0.556vw]">
                      <span class="flex-shrink-0 rounded-full w-[0.694vw] h-[0.694vw] bg-[#303236]"></span>
                      <span class="text-[#303236] font-normal text-[0.833vw] leading-[1.111vw]">
                        {{- first_val -}}
                      </span>
                    </div>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>

            {%- comment -%} Bottom: divider + price + CTA {%- endcomment -%}
            <div>
              {%- if card_variant != blank -%}
                <form action="/cart/add" method="post">
                  <input type="hidden" name="id" value="{{ card_variant.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button
                    type="submit"
                    class="flex items-center justify-center ml-auto text-[0.972vw] w-[8.958vw] bg-[#EBEBEB] text-[#111111] px-[0.833vw] py-[0.556vw] leading-[1.389vw] gap-[1.111vw]"
                  >
                    Add to cart <span>{% render 'button-arrow' %}</span>
                  </button>
                </form>
              {%- else -%}
                <a
                  href="{{ card_url }}"
                  class="flex items-center justify-center ml-auto text-[0.972vw] w-[8.958vw] bg-[#EBEBEB] text-[#111111] px-[0.833vw] py-[0.556vw] leading-[1.389vw] gap-[1.111vw]"
                >
                  View product <span>{% render 'button-arrow' %}</span>
                </a>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Product Accordion Cards",
  "tag": "section",
  "settings": [],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Accordion Cards",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
