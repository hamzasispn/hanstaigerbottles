<div class="breadcrumb pt-[24vw] lg:pt-[10.694vw]">
  <div class="max-w-[92vw] lg:max-w-[88.889vw] mx-auto">
    {% render 'section-header',
      label: section.settings.label,
      heading: section.settings.heading,
      description: section.settings.description,
      link: section.settings.link,
      link_text: section.settings.link_text
    %}

    {% render 'banner-box',
      bg-image: section.settings.banner-img,
      banner_link: section.settings.banner-btn-link,
      banner_btn_text: section.settings.banner_btn_text
     %}
  </div>
</div>

{% schema %}
{
  "name": "Banner",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Breadcrumb"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Breadcrumb"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Header Link URL"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Header Link Text"
    },
    {
      "type": "image_picker",
      "id": "banner-img",
      "label": "Banner Image"
    },
    {
      "type": "url",
      "id": "banner-btn-link",
      "label": "Banner Btn Link"
    },
    {
      "type": "text",
      "id": "banner_btn_text",
      "label": "Banner Btn Text"
    }
  ],
  "presets": [
    {
      "name": "Banner Section"
    }
  ]
}
{% endschema %}
