<div class="breadcrumb">
  <div class="max-w-[88.889vw] mx-auto">
    {% render 'section-header',
      label: section.settings.label,
      heading: section.settings.heading,
      description: section.settings.description,
      link: section.settings.link,
      link_text: section.settings.link_text
    %}
  </div>
</div>

{% schema %}
{
  "name": "Banner",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Breadcrumb"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Breadcrumb"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
    },
    {
      "type": "url",
      "id": "link",
      "label": "Header Link URL"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Header Link Text"
    }
  ]
}
{% endschema %}
