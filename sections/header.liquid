{%- liquid
  assign menu_items = section.blocks | where: 'type', 'menu_item'
  assign overview_label = section.settings.overview_label | default: 'Overview'
  assign header_text = section.settings.header_text
  assign cart_heading = section.settings.cart_heading | default: 'Cart'

  assign current_label = overview_label
  case template.name
    when 'product'
      assign current_label = product.title
    when 'collection'
      assign current_label = collection.title
    when 'article'
      assign current_label = article.title
    when 'blog'
      assign current_label = blog.title
    when 'page'
      assign current_label = page.title
    when 'cart'
      assign current_label = cart_heading
    when 'search'
      assign current_label = 'Search'
    when 'customers/account'
      assign current_label = 'Account'
    when 'customers/login'
      assign current_label = 'Sign in'
    when 'customers/register'
      assign current_label = 'Register'
    when 'customers/order'
      assign current_label = 'Order'
    when 'customers/addresses'
      assign current_label = 'Addresses'
  endcase

  assign always_dark = false
  unless template.name == 'index' or template.name == 'password'
    assign always_dark = true
  endunless

  assign mobile_logo_w = section.settings.logo_width | times: 2.8
  assign logo_alt = header_text | default: shop.name
  assign light_logo = settings.logo_image | default: settings.logo_image_dark
  assign dark_logo = settings.logo_image_dark | default: settings.logo_image
-%}

<style>[x-cloak] { display: none !important; }</style>
<script>
  document.addEventListener('alpine:init', () => {
    Alpine.store('cart', {
      open: false,
      loading: false,
      busyKey: null,
      count: {{ cart.item_count | json }},
      total: {{ cart.total_price | json }},
      currency: {{ cart.currency.symbol | json }},
      items: [],
      money(cents) {
        return this.currency + (cents / 100).toFixed(2);
      },
      openDrawer() { this.open = true; },
      close() { this.open = false; },
      async refresh() {
        this.loading = true;
        try {
          const res = await fetch('/cart.js', { headers: { Accept: 'application/json' } });
          const data = await res.json();
          this.count = data.item_count;
          this.total = data.total_price;
          this.items = data.items.map(i => ({
            key: i.key,
            product_title: i.product_title,
            variant_title: i.variant_title,
            title: i.title,
            url: i.url,
            image: i.image || '',
            quantity: i.quantity,
            final_line_price: i.final_line_price,
          }));
        } finally {
          this.loading = false;
        }
      },
      async update(key, quantity) {
        this.busyKey = key;
        try {
          await fetch('/cart/change.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: key, quantity })
          });
          await this.refresh();
        } finally {
          this.busyKey = null;
        }
      },
    });

    Alpine.store('cart').refresh();

    window.addEventListener('cart:refresh', async () => {
      await Alpine.store('cart').refresh();
      setTimeout(() => Alpine.store('cart').openDrawer(), 0);
    });
    window.addEventListener('cart:open', () => {
      setTimeout(() => Alpine.store('cart').openDrawer(), 0);
    });
  });
</script>

<header
  x-data="{ openMenu: false, openLang: false, scrolled: false }"
  x-init="
    const update = () => { const s = window.scrollY > 80; if (s !== scrolled) scrolled = s; };
    update();
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { update(); ticking = false; });
    }, { passive: true });
  "
  :data-dark="({{ always_dark }} || scrolled).toString()"
  data-dark="{{ always_dark }}"
  class="site-header group/header fixed top-[7vw] lg:top-[2vw] left-0 right-0 z-50 w-full pt-[3vw] lg:pt-[2vw] pb-[3vw] lg:pb-[1vw]"
>
  <div
    class="grid grid-cols-12 lg:grid-cols-3 lg:items-start gap-0 lg:gap-[1vw] max-w-[92vw] lg:p-0 p-[4.211vw] rounded-[2.105vw] lg:max-w-[88.889vw] mx-auto lg:rounded-none bg-black/40 lg:bg-transparent lg:shadow-none"
    :class="openMenu ? 'items-start' : 'items-center'"
  >
    {%- comment -%} ── Overview / Menu (desktop only) ─────────── {%- endcomment -%}
    <div
      class="relative justify-self-start  lg:bg-black/40 px-[4vw] lg:px-[1.1vw] py-[2.5vw] lg:py-[0.85vw] text-[3vw] lg:text-[0.85vw] lg:col-span-1"
      @click.outside="openMenu = false"
      :class="openMenu ? 'w-[50vw] lg:w-[16vw] rounded-t-[1.5vw] lg:rounded-t-[0.4vw]' : 'w-fit rounded-[1.5vw] lg:rounded-[0.4vw] lg:backdrop-blur-md'"
    >
      <button
        type="button"
        @click="openMenu = !openMenu"
        class="flex items-center justify-between gap-[2.5vw] lg:gap-[0.7vw] font-(--font-primary--family) tracking-[0.05em] w-full text-white"
        :aria-expanded="openMenu"
      >
        <span class="lg:block hidden truncate max-w-[12vw]">{{ current_label }}</span>
        <span class="grid grid-cols-2 gap-[0.4vw] lg:gap-[0.15vw]">
          <span class="w-[0.5vw] h-[0.5vw] lg:w-[0.15vw] lg:h-[0.15vw] rounded-full bg-white"></span>
          <span class="w-[0.5vw] h-[0.5vw] lg:w-[0.15vw] lg:h-[0.15vw] rounded-full bg-white"></span>
          <span
            class="w-[0.5vw] h-[0.5vw] lg:w-[0.15vw] lg:h-[0.15vw] rounded-full lg:block hidden"
            :class="openMenu ? 'bg-transparent' : 'bg-white'"
          ></span>
          <span
            class="w-[0.5vw] h-[0.5vw] lg:w-[0.15vw] lg:h-[0.15vw] rounded-full lg:block hidden"
            :class="openMenu ? 'bg-transparent' : 'bg-white'"
          ></span>
        </span>
      </button>

      {%- if menu_items.size > 0 -%}
        <div
          x-cloak
          x-show="openMenu"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 -translate-y-[2vw] scale-95"
          x-transition:enter-end="opacity-100 translate-y-0 scale-100"
          x-transition:leave="transition ease-in duration-200"
          x-transition:leave-start="opacity-100 translate-y-0 scale-100"
          x-transition:leave-end="opacity-0 -translate-y-[2vw] scale-95"
          class="pt-[4vw] lg:pt-[0.8vw] origin-top-left flex flex-col bg-black/70 lg:bg-black/60 lg:backdrop-blur-md rounded-b-[1.5vw] lg:rounded-b-[0.4vw] absolute left-0 top-full w-full"
        >
          {%- for block in menu_items -%}
            {%- liquid
              assign is_active = false
              assign link_path = block.settings.link | default: ''
              if link_path != '' and link_path != '#'
                if request.path == link_path
                  assign is_active = true
                elsif link_path != '/' and request.path contains link_path
                  assign is_active = true
                endif
              endif
            -%}
            <a
              href="{{ block.settings.link | default: '#' }}"
              class="relative flex items-center gap-[3vw] lg:gap-[0.8vw] text-white text-[3.5vw] lg:text-[0.9vw] rounded-[1vw] lg:rounded-[0.25vw] p-[1.5vw] lg:p-[0.4vw] pr-[5vw] lg:pr-[1.4vw] transition-colors {% if is_active %}bg-white/10{% else %}hover:bg-white/10{% endif %}"
              {% if is_active %}aria-current="page"{% endif %}
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.image -%}
                {{
                  block.settings.image
                  | image_url: width: 120
                  | image_tag:
                    class: 'w-[10vw] h-[10vw] lg:w-[2.5vw] lg:h-[2.5vw] object-cover rounded-[0.8vw] lg:rounded-[0.2vw] bg-white/10'
                }}
              {%- else -%}
                <span
                  class="w-[10vw] h-[10vw] lg:w-[2.5vw] lg:h-[2.5vw] bg-white/10 rounded-[0.8vw] lg:rounded-[0.2vw]"
                ></span>
              {%- endif -%}
              <span>{{ block.settings.label }}</span>
              {%- if is_active -%}
                <span
                  class="absolute right-[2vw] lg:right-[0.6vw] top-1/2 -translate-y-1/2 w-[1.4vw] h-[1.4vw] lg:w-[0.35vw] lg:h-[0.35vw] bg-white rounded-full"
                  aria-hidden="true"
                ></span>
              {%- endif -%}
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── Wordmark ─────────────────────────────────── {%- endcomment -%}
    <a
      href="{{ routes.root_url }}"
      class="flex items-center justify-self-start lg:justify-self-center lg:col-span-1 col-span-6"
    >
      {%- if light_logo != blank or dark_logo != blank -%}
        <span class="relative block w-[{{ mobile_logo_w }}vw] lg:w-[{{ section.settings.logo_width }}vw]">
          <img
            src="{{ light_logo | image_url: width: 600 }}"
            alt="{{ logo_alt | escape }}"
            class="block w-full object-contain opacity-100 lg:group-data-[dark=true]/header:opacity-0"
          >
          <img
            src="{{ dark_logo | image_url: width: 600 }}"
            alt=""
            aria-hidden="true"
            class="absolute inset-0 w-full h-full object-contain opacity-0 lg:group-data-[dark=true]/header:opacity-100"
          >
        </span>
      {%- else -%}
        <span class="text-[3.5vw] lg:text-[1.4vw] tracking-[0.5em] font-medium uppercase text-white/80 lg:group-data-[dark=true]/header:text-black/80">
          {{ header_text | default: shop.name }}
        </span>
      {%- endif -%}
    </a>

    {%- comment -%} ── Right cluster ───────────────────────────── {%- endcomment -%}
    <div class="lg:col-span-1 col-span-5">
      {%- comment -%} Mobile: clean inline cluster (no pill) {%- endcomment -%}
      {%- assign langs = localization.available_languages -%}
      {%- if langs.size == 0 -%}{%- assign langs = shop.published_locales -%}{%- endif -%}
      <div
        class="lg:hidden ml-auto flex items-center justify-end gap-[3.5vw] tracking-[0.1em] uppercase text-white"
      >
        <div class="relative" @click.outside="openLang = false">
          <button
            type="button"
            @click="openLang = !openLang"
            class="text-[3vw] font-medium"
            :aria-expanded="openLang"
            aria-label="Select language"
          >
            {{- localization.language.iso_code | upcase | default: 'EN' -}}
          </button>
          <div
            x-cloak
            x-show="openLang"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 -translate-y-[1vw]"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-150"
            class="absolute right-0 top-full mt-[2vw] min-w-[28vw] origin-top-right bg-black/85 text-white rounded-[1vw] p-[2vw] flex flex-col z-50"
          >
            {%- form 'localization' -%}
              <input type="hidden" name="_method" value="put">
              {%- for language in langs -%}
                <button
                  type="submit"
                  name="locale_code"
                  value="{{ language.iso_code }}"
                  class="text-left px-[2vw] py-[1.5vw] text-[3vw] hover:bg-white/10 rounded-[0.5vw] {% if language.iso_code == localization.language.iso_code %}opacity-60{% endif %}"
                >
                  {{ language.endonym_name | default: language.name }}
                </button>
              {%- endfor -%}
            {%- endform -%}
          </div>
        </div>

        <span
          class="block w-px h-[3.5vw] bg-white/50"
          aria-hidden="true"
        ></span>

        <a
          href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
          class="flex items-center"
          aria-label="{% if customer %}{{ 'customer.account' | t | default: 'Account' }}{% else %}{{ 'customer.sign_in' | t | default: 'Sign in' }}{% endif %}"
        >
          {% render 'icon-account', class: 'w-[4.5vw] h-[4.5vw]' %}
        </a>

        <button
          type="button"
          @click="$store.cart.open ? $store.cart.close() : $store.cart.openDrawer()"
          class="relative flex items-center justify-center"
          aria-label="Open cart"
        >
          {% render 'icon-cart', class: 'w-[4.5vw] h-[4.5vw]' %}
          <span
            x-show="!$store.cart.loading && $store.cart.count > 0"
            x-text="$store.cart.count"
            class="absolute -top-[1vw] -right-[1.5vw] flex items-center justify-center min-w-[3vw] h-[3vw] px-[0.5vw] rounded-full bg-white text-black text-[2vw] font-medium leading-none"
          ></span>
        </button>
      </div>

      {%- comment -%} Desktop: pill cluster {%- endcomment -%}
      <div
        class="hidden lg:flex ml-auto w-fit items-center justify-end gap-[0.6vw] bg-black/40 rounded-[0.4vw] px-[0.9vw] py-[0.5vw] text-white"
        :class="!openLang && 'backdrop-blur-md'"
      >
        {%- comment -%} Language {%- endcomment -%}
        <div class="relative" @click.outside="openLang = false">
          <button
            type="button"
            @click="openLang = !openLang"
            class="flex items-center gap-[0.4vw] text-[0.85vw] font-(--font-primary--family) tracking-[0.05em] px-[0.5vw] py-[0.4vw]"
            :aria-expanded="openLang"
            aria-label="Select language"
          >
            <span>{{- localization.language.endonym_name | default: localization.language.name -}}</span>
            <svg
              class="block w-[0.85vw] h-[0.85vw] transition-transform"
              :class="openLang && '-rotate-180'"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M4 6l4 4 4-4"/>
            </svg>
          </button>

          <div
            x-cloak
            x-show="openLang"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 -translate-y-[2vw] scale-95"
            x-transition:enter-end="opacity-100 translate-y-0 scale-100"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="opacity-100 translate-y-0 scale-100"
            x-transition:leave-end="opacity-0 -translate-y-[2vw] scale-95"
            class="absolute right-0 top-full mt-[0.4vw] min-w-[8vw] font-(--font-primary--family) origin-top-right bg-black/80 backdrop-blur-md rounded-[0.3vw] p-[0.5vw] flex flex-col"
          >
            {%- form 'localization' -%}
              <input type="hidden" name="_method" value="put">
              {%- for language in langs -%}
                <button
                  type="submit"
                  name="locale_code"
                  value="{{ language.iso_code }}"
                  class="text-left px-[0.5vw] py-[0.35vw] text-[0.85vw] hover:bg-white/10 rounded-[0.2vw] {% if language.iso_code == localization.language.iso_code %}opacity-60{% endif %}"
                >
                  {{ language.endonym_name | default: language.name }}
                </button>
              {%- endfor -%}
            {%- endform -%}
          </div>
        </div>

        {%- comment -%} Sign in {%- endcomment -%}
        <a
          href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
          class="flex items-center font-(--font-primary--family) tracking-[0.05em] px-[0.5vw] py-[0.4vw] text-[0.85vw]"
          aria-label="{% if customer %}{{ 'customer.account' | t | default: 'Account' }}{% else %}{{ 'customer.sign_in' | t | default: 'Sign in' }}{% endif %}"
        >
          {%- if customer -%}
            {{ 'customer.account' | t | default: 'Account' }}
          {%- else -%}
            {{ 'customer.sign_in' | t | default: 'Sign in' }}
          {%- endif -%}
        </a>

        {%- comment -%} Cart {%- endcomment -%}
        <div class="relative" @click.outside="$store.cart.close()">
          <button
            type="button"
            @click="$store.cart.open ? $store.cart.close() : $store.cart.openDrawer()"
            class="flex items-center gap-[0.4vw] bg-white/15 rounded-[0.2vw] px-[0.6vw] py-[0.4vw] text-[0.85vw] font-(--font-primary--family) tracking-[0.05em] hover:bg-white/25 transition-colors"
            aria-label="Open cart"
          >
            <span>{{ 'cart.title' | t | default: 'Cart' }}</span>
            <span class="relative min-w-[0.85vw] text-center inline-flex items-center justify-center">
              <span x-show="!$store.cart.loading && $store.cart.open" aria-hidden="true">{% render 'minus' %}</span>
              <span class="w-4.5 h-4.5" x-show="!$store.cart.loading && !$store.cart.open && $store.cart.count === 0" aria-hidden="true">{% render 'plus-icon' %}</span>
              <span x-show="!$store.cart.loading && !$store.cart.open && $store.cart.count > 0" x-text="$store.cart.count"></span>
              <svg
                x-show="$store.cart.loading"
                x-cloak
                class="inline-block w-[0.85vw] h-[0.85vw] animate-spin"
                viewBox="0 0 24 24"
                fill="none"
              >
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/>
                <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
              </svg>
            </span>
          </button>
        </div>
      </div>

      {% render 'cart-drawer', heading: cart_heading %}
    </div>
  </div>
</header>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "If set, replaces the centered wordmark."
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 4,
      "max": 30,
      "step": 1,
      "unit": "vw",
      "default": 12
    },
    {
      "type": "text",
      "id": "header_text",
      "label": "Header text",
      "info": "Centered wordmark. Leave empty to use the shop name.",
      "default": "HANSTAIGER WORLD"
    },
    {
      "type": "text",
      "id": "overview_label",
      "label": "Overview button label",
      "default": "Overview"
    },
    {
      "type": "text",
      "id": "cart_heading",
      "label": "Cart drawer heading",
      "default": "Cart"
    }
  ],
  "blocks": [
    {
      "type": "menu_item",
      "name": "Menu item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Item"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.header",
      "blocks": [
        { "type": "menu_item", "settings": { "label": "Bottles" } },
        { "type": "menu_item", "settings": { "label": "Electrolytes" } },
        { "type": "menu_item", "settings": { "label": "Gear" } },
        { "type": "menu_item", "settings": { "label": "The X1" } },
        { "type": "menu_item", "settings": { "label": "B2B" } }
      ]
    }
  ]
}
{% endschema %}
