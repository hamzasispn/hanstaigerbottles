{%- liquid
  assign menu_items = section.blocks | where: 'type', 'menu_item'
  assign overview_label = section.settings.overview_label | default: 'Overview'
  assign header_text = section.settings.header_text
  assign cart_heading = section.settings.cart_heading | default: 'Cart'

  assign current_label = overview_label
  case template.name
    when 'product'
      assign current_label = product.title
    when 'collection'
      assign current_label = collection.title
    when 'article'
      assign current_label = article.title
    when 'blog'
      assign current_label = blog.title
    when 'page'
      assign current_label = page.title
    when 'cart'
      assign current_label = cart_heading
    when 'search'
      assign current_label = 'Search'
    when 'customers/account'
      assign current_label = 'Account'
    when 'customers/login'
      assign current_label = 'Sign in'
    when 'customers/register'
      assign current_label = 'Register'
    when 'customers/order'
      assign current_label = 'Order'
    when 'customers/addresses'
      assign current_label = 'Addresses'
  endcase
-%}

<style>
  [x-cloak] {
    display: none !important;
  }
  .site-header {
    will-change: background-color;
    transform: translateZ(0);
    backface-visibility: hidden;
  }
</style>
<script>
  document.addEventListener('alpine:init', () => {
    Alpine.store('cart', {
      open: false,
      loading: false,
      busyKey: null,
      count: {{ cart.item_count | json }},
      total: {{ cart.total_price | json }},
      currency: {{ cart.currency.symbol | json }},
      items: [],
      money(cents) {
        return this.currency + (cents / 100).toFixed(2);
      },
      openDrawer() { this.open = true; },
      close() { this.open = false; },
      async refresh() {
        this.loading = true;
        try {
          const res = await fetch('/cart.js', { headers: { Accept: 'application/json' } });
          const data = await res.json();
          this.count = data.item_count;
          this.total = data.total_price;
          this.items = data.items.map(i => ({
            key: i.key,
            product_title: i.product_title,
            variant_title: i.variant_title,
            title: i.title,
            url: i.url,
            image: i.image || '',
            quantity: i.quantity,
            final_line_price: i.final_line_price,
          }));
        } finally {
          this.loading = false;
        }
      },
      async update(key, quantity) {
        this.busyKey = key;
        try {
          await fetch('/cart/change.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: key, quantity })
          });
          await this.refresh();
        } finally {
          this.busyKey = null;
        }
      },
    });

    Alpine.store('cart').refresh();

    window.addEventListener('cart:refresh', async () => {
      await Alpine.store('cart').refresh();
      setTimeout(() => Alpine.store('cart').openDrawer(), 0);
    });
    window.addEventListener('cart:open', () => {
      setTimeout(() => Alpine.store('cart').openDrawer(), 0);
    });
  });
</script>

<header
  x-data="{ openMenu: false, openLang: false, scrolled: false }"
  x-init="
    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        scrolled = window.scrollY > 10;
        ticking = false;
      });
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  "
  :class="scrolled ? 'shadow-sm bg-white/70 backdrop-blur-md fixed top-0' : 'absolute top-[7vw]'"
  class="site-header left-0 right-0 z-50 w-full pt-[3vw] lg:pt-[2vw] pb-[3vw] lg:pb-[1vw] transition-[background-color,box-shadow] duration-300"
>
  <div
    class="grid grid-cols-12 lg:grid-cols-3 lg:items-start gap-[2vw] lg:gap-[1vw] max-w-[92vw] lg:max-w-[88.889vw] mx-auto"
    :class="openMenu ? 'items-start' : 'items-center'"
  >
    {%- comment -%} ── Overview / Menu ───────────────────────────── {%- endcomment -%}
    <div
      class="relative justify-self-start bg-black/40 px-[4vw] lg:px-[1.1vw] py-[2.5vw] lg:py-[0.85vw] text-[3vw] lg:text-[0.85vw] lg:col-span-1 col-span-2"
      @click.outside="openMenu = false"
      :class="openMenu ? 'w-[50vw] lg:w-[16vw] rounded-t-[1.5vw] lg:rounded-t-[0.4vw]' : 'w-fit rounded-[1.5vw] lg:rounded-[0.4vw] backdrop-blur-3xl'"
    >
      <button
        type="button"
        @click="openMenu = !openMenu"
        class="flex items-center justify-between gap-[2.5vw] lg:gap-[0.7vw]  text-white font-(--font-primary--family) tracking-[0.05em] w-full"
        :aria-expanded="openMenu"
      >
        <span class="lg:block hidden truncate max-w-[12vw]">{{ current_label }}</span>
        <span class="grid grid-cols-2 gap-[0.4vw] lg:gap-[0.15vw]">
          <span class="w-[0.5vw] h-[0.5vw] lg:w-[0.15vw] lg:h-[0.15vw] bg-white rounded-full"></span>
          <span class="w-[0.5vw] h-[0.5vw] lg:w-[0.15vw] lg:h-[0.15vw] bg-white rounded-full"></span>
          <span
            class="w-[0.5vw] h-[0.5vw] lg:w-[0.15vw] lg:h-[0.15vw] rounded-full"
            :class="openMenu ? 'bg-transparent' : 'bg-white'"
          ></span>
          <span
            class="w-[0.5vw] h-[0.5vw] lg:w-[0.15vw] lg:h-[0.15vw] rounded-full"
            :class="openMenu ? 'bg-transparent' : 'bg-white'"
          ></span>
        </span>
      </button>

      {%- if menu_items.size > 0 -%}
        <div
          x-cloak
          x-show="openMenu"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 -translate-y-[2vw] scale-95"
          x-transition:enter-end="opacity-100 translate-y-0 scale-100"
          x-transition:leave="transition ease-in duration-200"
          x-transition:leave-start="opacity-100 translate-y-0 scale-100"
          x-transition:leave-end="opacity-0 -translate-y-[2vw] scale-95"
          class="pt-[4vw] lg:pt-[0.8vw] origin-top-left flex flex-col bg-black/40 backdrop-blur-3xl rounded-b-[1.5vw] lg:rounded-b-[0.4vw] absolute left-0 top-full w-full"
        >
          {%- for block in menu_items -%}
            {%- liquid
              assign is_active = false
              assign link_path = block.settings.link | default: ''
              if link_path != '' and link_path != '#'
                if request.path == link_path
                  assign is_active = true
                elsif link_path != '/' and request.path contains link_path
                  assign is_active = true
                endif
              endif
            -%}
            <a
              href="{{ block.settings.link | default: '#' }}"
              class="relative flex items-center gap-[3vw] lg:gap-[0.8vw] text-white text-[3.5vw] lg:text-[0.9vw] rounded-[1vw] lg:rounded-[0.25vw] p-[1.5vw] lg:p-[0.4vw] pr-[5vw] lg:pr-[1.4vw] transition-colors {% if is_active %}bg-white/10{% else %}hover:bg-white/10{% endif %}"
              {% if is_active %}aria-current="page"{% endif %}
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.image -%}
                {{
                  block.settings.image
                  | image_url: width: 120
                  | image_tag:
                    class: 'w-[10vw] h-[10vw] lg:w-[2.5vw] lg:h-[2.5vw] object-cover rounded-[0.8vw] lg:rounded-[0.2vw] bg-white/10'
                }}
              {%- else -%}
                <span
                  class="w-[10vw] h-[10vw] lg:w-[2.5vw] lg:h-[2.5vw] bg-white/10 rounded-[0.8vw] lg:rounded-[0.2vw]"
                ></span>
              {%- endif -%}
              <span>{{ block.settings.label }}</span>
              {%- if is_active -%}
                <span
                  class="absolute right-[2vw] lg:right-[0.6vw] top-1/2 -translate-y-1/2 w-[1.4vw] h-[1.4vw] lg:w-[0.35vw] lg:h-[0.35vw] bg-white rounded-full"
                  aria-hidden="true"
                ></span>
              {%- endif -%}
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── Wordmark ─────────────────────────────────── {%- endcomment -%}
    {%- assign use_dark_logo = false -%}
    {%- unless template.name == 'index' or template.name == 'password' -%}
      {%- assign use_dark_logo = true -%}
    {%- endunless -%}
    <a
      href="{{ routes.root_url }}"
      class="flex items-center justify-self-center lg:col-span-1 col-span-6"
    >
      {%- if settings.logo_image != blank or settings.logo_image_dark != blank -%}
        {%- assign mobile_logo_w = section.settings.logo_width | times: 2.8 -%}
        {%- assign logo_style = 'width:' | append: mobile_logo_w | append: 'vw;' -%}
        {%- assign logo_style_lg = 'width:' | append: section.settings.logo_width | append: 'vw;' -%}
        {%- assign logo_alt = header_text | default: shop.name -%}
        {%- if use_dark_logo and settings.logo_image_dark != blank -%}
          {%- assign active_logo = settings.logo_image_dark -%}
        {%- else -%}
          {%- assign active_logo = settings.logo_image | default: settings.logo_image_dark -%}
        {%- endif -%}
        <img
          src="{{ active_logo | image_url: width: 600 }}"
          alt="{{ logo_alt | escape }}"
          class="block object-contain w-full lg:w-[var(--logo-w)]"
          style="--logo-w: {{ section.settings.logo_width }}vw;"
        >
      {%- else -%}
        <span class="text-[3.5vw] lg:text-[1.4vw] tracking-[0.5em] font-medium {% if use_dark_logo %}text-black/80{% else %}text-white/80{% endif %} uppercase">
          {{ header_text | default: shop.name }}
        </span>
      {%- endif -%}
    </a>

    {%- comment -%} ── Right cluster ───────────────────────────── {%- endcomment -%}
    <div class="lg:col-span-1 col-span-4">
      <div
        class="ml-auto w-fit flex items-center justify-end gap-[2vw] lg:gap-[0.6vw] bg-black/40 rounded-[1.5vw] lg:rounded-[0.4vw] px-[3vw] lg:px-[0.9vw] py-[1.5vw] lg:py-[0.5vw] text-white"
        :class="!openLang && 'backdrop-blur-3xl'"
      >
        {%- comment -%} Language {%- endcomment -%}
        {%- assign langs = localization.available_languages -%}
        {%- if langs.size == 0 -%}{%- assign langs = shop.published_locales -%}{%- endif -%}
        <div class="relative" @click.outside="openLang = false">
          <button
            type="button"
            @click="openLang = !openLang"
            class="flex items-center gap-[1.5vw] lg:gap-[0.4vw] text-[3vw] lg:text-[0.85vw] font-(--font-primary--family) tracking-[0.05em] px-[1.5vw] lg:px-[0.5vw] py-[1.5vw] lg:py-[0.4vw]"
            :aria-expanded="openLang"
            aria-label="Select language"
          >
            {%- comment -%} Mobile: globe icon {%- endcomment -%}
            <svg
              class="lg:hidden w-[4.5vw] h-[4.5vw]"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="9"/>
              <path d="M3 12h18"/>
              <path d="M12 3c2.5 3 2.5 15 0 18"/>
              <path d="M12 3c-2.5 3-2.5 15 0 18"/>
            </svg>
            {%- comment -%} Desktop: language name + chevron {%- endcomment -%}
            <span class="hidden lg:inline">
              {{- localization.language.endonym_name | default: localization.language.name -}}
            </span>
            <svg
              class="hidden lg:block w-[0.85vw] h-[0.85vw] transition-transform"
              :class="openLang && '-rotate-180'"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M4 6l4 4 4-4"/>
            </svg>
          </button>

          <div
            x-cloak
            x-show="openLang"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 -translate-y-[2vw] scale-95"
            x-transition:enter-end="opacity-100 translate-y-0 scale-100"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="opacity-100 translate-y-0 scale-100"
            x-transition:leave-end="opacity-0 -translate-y-[2vw] scale-95"
            class="absolute right-0 top-full mt-[1.5vw] lg:mt-[0.4vw] min-w-[28vw] lg:min-w-[8vw] font-(--font-primary--family) origin-top-right bg-black/60 backdrop-blur-3xl rounded-[1vw] lg:rounded-[0.3vw] p-[2vw] lg:p-[0.5vw] flex flex-col"
          >
            {%- form 'localization' -%}
              <input type="hidden" name="_method" value="put">
              {%- for language in langs -%}
                <button
                  type="submit"
                  name="locale_code"
                  value="{{ language.iso_code }}"
                  class="text-left px-[2vw] lg:px-[0.5vw] py-[1.5vw] lg:py-[0.35vw] text-[3vw] lg:text-[0.85vw] hover:bg-white/10 rounded-[0.5vw] lg:rounded-[0.2vw] {% if language.iso_code == localization.language.iso_code %}opacity-60{% endif %}"
                >
                  {{ language.endonym_name | default: language.name }}
                </button>
              {%- endfor -%}
            {%- endform -%}
          </div>
        </div>

        {%- comment -%} Sign in {%- endcomment -%}
        <a
          href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
          class="flex items-center font-(--font-primary--family) tracking-[0.05em] px-[1.5vw] lg:px-[0.5vw] py-[1.5vw] lg:py-[0.4vw]"
          aria-label="{% if customer %}{{ 'customer.account' | t | default: 'Account' }}{% else %}{{ 'customer.sign_in' | t | default: 'Sign in' }}{% endif %}"
        >
          {%- comment -%} Mobile: person icon {%- endcomment -%}
          <svg
            class="lg:hidden w-[4.5vw] h-[4.5vw]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="8" r="4"/>
            <path d="M4 21c1.5-4 5-6 8-6s6.5 2 8 6"/>
          </svg>
          {%- comment -%} Desktop: text {%- endcomment -%}
          <span class="hidden lg:inline text-[0.85vw]">
            {%- if customer -%}
              {{ 'customer.account' | t | default: 'Account' }}
            {%- else -%}
              {{ 'customer.sign_in' | t | default: 'Sign in' }}
            {%- endif -%}
          </span>
        </a>

        {%- comment -%} Cart {%- endcomment -%}
        <div class="relative" @click.outside="$store.cart.close()">
          {%- comment -%} Mobile: icon-only bag {%- endcomment -%}
          <button
            type="button"
            @click="$store.cart.open ? $store.cart.close() : $store.cart.openDrawer()"
            class="lg:hidden relative flex items-center justify-center px-[1.5vw] py-[1.5vw]"
            aria-label="Open cart"
          >
            <svg
              class="w-[5vw] h-[5vw]"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 7h14l-1.2 12.2a2 2 0 0 1-2 1.8H8.2a2 2 0 0 1-2-1.8L5 7z"/>
              <path d="M9 7V5a3 3 0 0 1 6 0v2"/>
            </svg>
            {%- comment -%} Indicator: plus (empty), minus (open), or count {%- endcomment -%}
            <span
              x-show="!$store.cart.loading && $store.cart.open"
              class="absolute -top-[0.5vw] -right-[0.5vw] flex items-center justify-center w-[3.5vw] h-[3.5vw] rounded-full bg-white text-black text-[2.2vw] font-medium leading-none"
              aria-hidden="true"
            >−</span>
            <span
              x-show="!$store.cart.loading && !$store.cart.open && $store.cart.count === 0"
              class="absolute -top-[0.5vw] -right-[0.5vw] flex items-center justify-center w-[3.5vw] h-[3.5vw] rounded-full bg-white text-black text-[2.2vw] font-medium leading-none"
              aria-hidden="true"
            >+</span>
            <span
              x-show="!$store.cart.loading && !$store.cart.open && $store.cart.count > 0"
              x-text="$store.cart.count"
              class="absolute -top-[0.5vw] -right-[0.5vw] flex items-center justify-center min-w-[3.5vw] h-[3.5vw] px-[0.6vw] rounded-full bg-white text-black text-[2.2vw] font-medium leading-none"
            ></span>
            <svg
              x-show="$store.cart.loading"
              x-cloak
              class="absolute -top-[0.5vw] -right-[0.5vw] w-[3.5vw] h-[3.5vw] animate-spin"
              viewBox="0 0 24 24"
              fill="none"
            >
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/>
              <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </button>

          {%- comment -%} Desktop: pill button with label + state indicator {%- endcomment -%}
          <button
            type="button"
            @click="$store.cart.open ? $store.cart.close() : $store.cart.openDrawer()"
            class="hidden lg:flex items-center gap-[0.4vw] bg-white/15 rounded-[0.2vw] px-[0.6vw] py-[0.4vw] text-[0.85vw] font-(--font-primary--family) tracking-[0.05em] hover:bg-white/25 transition-colors"
            aria-label="Open cart"
          >
            <span>{{ 'cart.title' | t | default: 'Cart' }}</span>
            <span class="relative min-w-[0.85vw] text-center inline-flex items-center justify-center">
              <span x-show="!$store.cart.loading && $store.cart.open" aria-hidden="true">{% render 'minus' %}</span>
              <span class="w-4.5 h-4.5" x-show="!$store.cart.loading && !$store.cart.open && $store.cart.count === 0" aria-hidden="true">{% render 'plus-icon' %}</span>
              <span x-show="!$store.cart.loading && !$store.cart.open && $store.cart.count > 0" x-text="$store.cart.count"></span>
              <svg
                x-show="$store.cart.loading"
                x-cloak
                class="inline-block w-[0.85vw] h-[0.85vw] animate-spin"
                viewBox="0 0 24 24"
                fill="none"
              >
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/>
                <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
              </svg>
            </span>
          </button>

          {% render 'cart-drawer', heading: cart_heading %}
        </div>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "If set, replaces the centered wordmark."
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 4,
      "max": 30,
      "step": 1,
      "unit": "vw",
      "default": 12
    },
    {
      "type": "text",
      "id": "header_text",
      "label": "Header text",
      "info": "Centered wordmark. Leave empty to use the shop name.",
      "default": "HANSTAIGER WORLD"
    },
    {
      "type": "text",
      "id": "overview_label",
      "label": "Overview button label",
      "default": "Overview"
    },
    {
      "type": "text",
      "id": "cart_heading",
      "label": "Cart drawer heading",
      "default": "Cart"
    }
  ],
  "blocks": [
    {
      "type": "menu_item",
      "name": "Menu item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Item"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.header",
      "blocks": [
        { "type": "menu_item", "settings": { "label": "Bottles" } },
        { "type": "menu_item", "settings": { "label": "Electrolytes" } },
        { "type": "menu_item", "settings": { "label": "Gear" } },
        { "type": "menu_item", "settings": { "label": "The X1" } },
        { "type": "menu_item", "settings": { "label": "B2B" } }
      ]
    }
  ]
}
{% endschema %}
