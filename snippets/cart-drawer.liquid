{% doc %}
  Cart dropdown anchored under the cart button. Same glass-pill style as the
  Overview menu. State comes from the global Alpine cart store.

  @param {string} [heading] - Optional heading text shown at the top of the drawer.

  @example
  {% render 'cart-drawer', heading: section.settings.cart_heading %}
{% enddoc %}

<div
  x-cloak
  x-show="$store.cart.open"
  @keydown.escape.window="$store.cart.close()"
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="opacity-0 -translate-y-[2vw] scale-95"
  x-transition:enter-end="opacity-100 translate-y-0 scale-100"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="opacity-100 translate-y-0 scale-100"
  x-transition:leave-end="opacity-0 -translate-y-[2vw] scale-95"
  class="absolute right-0 top-full mt-[2vw] lg:mt-[0.6vw] w-[90vw] sm:w-[70vw] lg:w-[24vw] origin-top-right bg-black/40 backdrop-blur-2xl rounded-[1.5vw] lg:rounded-[0.4vw] flex flex-col text-white max-h-[80vh] overflow-hidden"
>
  <div class="flex items-center justify-between px-[3vw] lg:px-[0.9vw] pt-[3vw] lg:pt-[0.8vw] pb-[2vw] lg:pb-[0.5vw]">
    <h2 class="text-[3.5vw] lg:text-[0.9vw] uppercase tracking-[0.08em]">
      {{ heading | default: 'Cart' }}
      <span class="opacity-60" x-text="'(' + $store.cart.count + ')'"></span>
    </h2>
    <button
      type="button"
      @click="$store.cart.close()"
      class="text-[5vw] lg:text-[1.2vw] leading-none opacity-70 hover:opacity-100"
      aria-label="Close cart"
    >&times;</button>
  </div>

  <div
    x-show="$store.cart.loading"
    x-transition.opacity
    class="absolute inset-0 z-10 flex items-center justify-center bg-black/30 backdrop-blur-sm"
  >
    <svg class="w-[8vw] h-[8vw] lg:w-[2vw] lg:h-[2vw] animate-spin text-white" viewBox="0 0 24 24" fill="none">
      <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/>
      <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
    </svg>
  </div>

  <div class="flex-1 overflow-y-auto px-[3vw] lg:px-[0.8vw]">
    <template x-if="$store.cart.count === 0">
      <p class="text-center py-[8vw] lg:py-[2vw] text-[3.2vw] lg:text-[0.85vw] opacity-70">
        {{ 'cart.empty' | t | default: 'Your cart is empty.' }}
      </p>
    </template>

    <ul class="divide-y divide-white/10">
      <template x-for="item in $store.cart.items" :key="item.key">
        <li class="flex gap-[2.5vw] lg:gap-[0.7vw] py-[3vw] lg:py-[0.7vw]">
          <a :href="item.url" class="block w-[18vw] h-[18vw] lg:w-[4.5vw] lg:h-[4.5vw] shrink-0 bg-white/10 rounded-[0.8vw] lg:rounded-[0.2vw] overflow-hidden">
            <img :src="item.image" :alt="item.title" class="w-full h-full object-contain" loading="lazy">
          </a>
          <div class="flex-1 flex flex-col justify-between min-w-0">
            <div class="flex justify-between gap-[2vw]">
              <div class="min-w-0">
                <a :href="item.url" class="block text-[3.2vw] lg:text-[0.85vw] font-medium leading-tight truncate" x-text="item.product_title"></a>
                <p class="text-[2.8vw] lg:text-[0.75vw] opacity-60 mt-[0.5vw] lg:mt-[0.15vw]" x-text="item.variant_title" x-show="item.variant_title"></p>
              </div>
              <p class="text-[3.2vw] lg:text-[0.85vw] font-medium shrink-0" x-text="$store.cart.money(item.final_line_price)"></p>
            </div>
            <div class="flex items-center justify-between mt-[2vw] lg:mt-[0.4vw]">
              <div class="flex items-center border border-white/20 rounded-[0.5vw] lg:rounded-[0.15vw]">
                <button type="button" :disabled="$store.cart.busyKey === item.key" @click="$store.cart.update(item.key, item.quantity - 1)" class="w-[7vw] h-[7vw] lg:w-[1.6vw] lg:h-[1.6vw] flex items-center justify-center text-[3.5vw] lg:text-[0.85vw] hover:bg-white/10 disabled:opacity-40" aria-label="Decrease">&minus;</button>
                <span class="w-[7vw] lg:w-[1.6vw] text-center text-[3vw] lg:text-[0.8vw]" x-text="item.quantity"></span>
                <button type="button" :disabled="$store.cart.busyKey === item.key" @click="$store.cart.update(item.key, item.quantity + 1)" class="w-[7vw] h-[7vw] lg:w-[1.6vw] lg:h-[1.6vw] flex items-center justify-center text-[3.5vw] lg:text-[0.85vw] hover:bg-white/10 disabled:opacity-40" aria-label="Increase">+</button>
              </div>
              <button type="button" :disabled="$store.cart.busyKey === item.key" @click="$store.cart.update(item.key, 0)" class="text-[2.8vw] lg:text-[0.7vw] uppercase tracking-[0.1em] underline opacity-60 hover:opacity-100 disabled:opacity-30">{{ 'cart.remove' | t | default: 'Remove' }}</button>
            </div>
          </div>
        </li>
      </template>
    </ul>
  </div>

  <div
    x-show="$store.cart.count > 0"
    class="px-[3vw] lg:px-[0.9vw] py-[3vw] lg:py-[0.8vw] border-t border-white/10 flex flex-col gap-[2vw] lg:gap-[0.5vw]"
  >
    <div class="flex justify-between text-[3.2vw] lg:text-[0.9vw] font-medium">
      <span>{{ 'cart.subtotal' | t | default: 'Subtotal' }}</span>
      <span x-text="$store.cart.money($store.cart.total)"></span>
    </div>
    <a href="{{ routes.cart_url }}" class="block text-center border border-white/40 py-[2.5vw] lg:py-[0.6vw] text-[3vw] lg:text-[0.8vw] uppercase tracking-[0.15em] rounded-[0.6vw] lg:rounded-[0.2vw] hover:bg-white/10 transition-colors">
      {{ 'cart.view_cart' | t | default: 'View cart' }}
    </a>
    <a href="/checkout" class="block text-center bg-white text-black py-[2.5vw] lg:py-[0.6vw] text-[3vw] lg:text-[0.8vw] uppercase tracking-[0.15em] rounded-[0.6vw] lg:rounded-[0.2vw] hover:opacity-80 transition-opacity">
      {{ 'cart.checkout' | t | default: 'Checkout' }}
    </a>
  </div>
</div>
