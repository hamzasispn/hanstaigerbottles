<div data-hero="card" class="hero-card max-w-[50.526vw] lg:max-w-[13.333vw] absolute bottom-0 right-0 p-[4.211vw] lg:p-[1.111vw] rounded-[1vw] lg:rounded-[0.417vw] bg-white/12 backdrop-blur-2xl">
  <div class="flex flex-col items-start gap-[2vw] lg:gap-[0.833vw]">
    <img
      height="94"
      width="160"
      src="{% if image %}{{ image | image_url: '2048x2048' }}{% else %}{{ 'hero-card.jpg' | asset_url }}{% endif %}"
      alt="Hanstaiger X1 Icon"
      class="w-full block h-[24.737vw] lg:h-[6.528vw]"
    >
    <a
      href="{{ link }}"
      class="capitalize text-white text-[2.8vw] leading-[3.6vw] lg:text-[0.972vw] lg:leading-[1.389vw] tracking-[0.02em] font-normal flex items-center gap-[1.2vw] lg:gap-[0.417vw]"
    >
      Check Bottles
      {% render 'icon-arrow' %}
    </a>
  </div>
</div>
