{%- comment -%}
  Snippet: product-card.liquid
  • product-card-image height set globally in section <style>
  • card--offset parent class overrides to shorter height
  • No inline styles except dynamic swatch background-color
{%- endcomment -%}

{%- liquid
  assign lazy        = lazy | default: true
  assign show_vendor = show_vendor | default: false
  assign current_var = product.selected_or_first_available_variant
  assign product_url = product.url | within: collection
-%}

<article
  class="group relative flex flex-col"
  x-data="{
    activeVariantId: {{ current_var.id | json }},
    addedToCart: false,
    addingToCart: false,
    async addToCart() {
      this.addingToCart = true;
      try {
        const res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: this.activeVariantId, quantity: 1 })
        });
        if (res.ok) {
          this.addedToCart = true;
          window.dispatchEvent(new CustomEvent('cart:refresh'));
          setTimeout(() => this.addedToCart = false, 2200);
        }
      } finally {
        this.addingToCart = false;
      }
    }
  }"
>

  {%- comment -%} ── Image ─────────────────────────────────────────── {%- endcomment -%}
  
  <a href="{{ product_url }}"
    class="product-card-image relative block overflow-hidden bg-[#ebebeb]"
    aria-label="{{ product.title | escape }}"
  >
    {%- if product.featured_media -%}
      {{
        product.featured_media
        | image_url: width: 800
        | image_tag:
          class: 'absolute inset-0 h-full w-full object-contain p-[7%] transition-transform duration-700 ease-out will-change-transform group-hover:scale-[1.04]',
          loading: lazy | ternary: 'lazy', 'eager',
          alt: product.featured_media.alt | escape | default: product.title,
          widths: '300,400,600,800',
          sizes: '(max-width: 767px) 50vw, (max-width: 1023px) 33vw, 25vw'
      }}
    {%- else -%}
      <span class="absolute inset-0 flex items-center justify-center">
        {{ 'image' | placeholder_svg_tag: 'w-10 h-10 opacity-10' }}
      </span>
    {%- endif -%}

    {%- if product.compare_at_price > product.price -%}
      <span class="absolute left-3 top-3 bg-black px-2 py-0.5 font-(--font-primary--family) text-[0.55rem] font-semibold uppercase tracking-[0.18em] text-white">
        Sale
      </span>
    {%- endif -%}
  </a>

  {%- comment -%} ── Body ──────────────────────────────────────────── {%- endcomment -%}
  <div class="flex flex-col gap-2.5 pt-3.5">

    {%- if show_vendor and product.vendor != blank -%}
      <p class="font-(--font-primary--family) text-[0.58rem] uppercase tracking-[0.2em] text-[#bbb]">
        {{ product.vendor }}
      </p>
    {%- endif -%}

    <div class="flex items-start justify-between gap-2">
      
      <a href="{{ product_url }}"
        class="font-(--font-primary--family) text-[0.82rem] font-medium leading-snug tracking-tight text-black transition-opacity hover:opacity-50"
      >
        {{ product.title }}
      </a>
      <span class="shrink-0 font-(--font-primary--family) text-[0.78rem] tabular-nums text-[#666]">
        {{ current_var.price | money }}
      </span>
    </div>

    {%- comment -%} ── Swatches + add to cart ────────────────────── {%- endcomment -%}
    {%- assign color_option = nil -%}
    {%- for option in product.options_with_values -%}
      {%- assign option_name_lower = option.name | downcase -%}
      {%- if option_name_lower == 'color' or option_name_lower == 'colour' -%}
        {%- assign color_option = option -%}
        {%- assign color_option_index = forloop.index0 -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    <div class="flex items-center justify-between gap-2 pt-1">

      {%- if color_option != nil -%}
        <div class="flex items-center gap-2" role="group" aria-label="Color options">
          {%- for value in color_option.values -%}
            {%- assign swatch_variant = nil -%}
            {%- for variant in product.variants -%}
              {%- if variant.options[color_option_index] == value and variant.available -%}
                {%- assign swatch_variant = variant -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if swatch_variant == nil -%}
              {%- for variant in product.variants -%}
                {%- if variant.options[color_option_index] == value -%}
                  {%- assign swatch_variant = variant -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
            {%- if swatch_variant -%}
              {%- assign value_handle = value | handleize -%}
              {%- assign css_color = value_handle
                | replace: 'orange', '#e86012'
                | replace: 'rust',   '#c0510e'
                | replace: 'blue',   '#2d3fcf'
                | replace: 'navy',   '#0a1a4a'
                | replace: 'black',  '#1a1a1a'
                | replace: 'white',  '#f0f0f0'
                | replace: 'red',    '#d62828'
                | replace: 'green',  '#2d6a4f'
                | replace: 'grey',   '#888888'
                | replace: 'gray',   '#888888'
                | replace: 'pink',   '#e879a0'
                | replace: 'yellow', '#f5c400'
                | replace: 'cream',  '#f0ead6'
                | replace: 'sand',   '#c8b89a'
              -%}
              <button
                type="button"
                @click.prevent="activeVariantId = {{ swatch_variant.id }}"
                :class="activeVariantId === {{ swatch_variant.id }}
                  ? 'ring-2 ring-black ring-offset-[2.5px] scale-110'
                  : 'ring-1 ring-transparent hover:ring-[#ccc] hover:ring-offset-[2px]'"
                class="h-3.5 w-3.5 rounded-full transition-all duration-200 will-change-transform"
                style="background-color: {{ css_color }};"
                aria-label="{{ value | escape }}"
                title="{{ value | escape }}"
              ></button>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <span></span>
      {%- endif -%}

      <button
        type="button"
        @click.prevent="addToCart()"
        :disabled="addingToCart"
        class="shrink-0 font-(--font-primary--family) text-[0.62rem] font-semibold uppercase tracking-[0.2em] text-black transition-opacity hover:opacity-40 disabled:cursor-wait disabled:opacity-30"
        aria-label="Add to cart"
      >
        <span x-show="!addedToCart && !addingToCart">Add to cart</span>
        <span x-show="addingToCart" x-cloak>…</span>
        <span x-show="addedToCart" x-cloak>✓ Added</span>
      </button>

    </div>
  </div>
</article>