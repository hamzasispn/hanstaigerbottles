{% comment %}
  Snippet: bundle-card-featured.liquid
  Large dark background featured product card (full-bleed image, dark overlay)
  Usage: {% render 'bundle-card-featured', block: block %}
{% endcomment %}

<div
  x-data="bundleCardFeatured()"
  class="relative overflow-hidden col-span-1"
  style="border-radius: 0.56vw; min-height: 34.03vw;"
  {{ block.shopify_attributes }}
>

  {%- comment -%} ── Background image (full bleed) ───────────────────────── {%- endcomment -%}
  <div class="absolute inset-0">
    {%- if block.settings.image != blank -%}
      <img
        src="{{ block.settings.image | image_url: width: 1200 }}"
        alt="{{ block.settings.title }}"
        class="w-full h-full object-cover"
        loading="lazy"
      >
    {%- else -%}
      <div class="w-full h-full bg-gradient-to-br from-[#2a4a5a] via-[#1a2a3a] to-[#0a0f14]"></div>
    {%- endif -%}
    {%- comment -%} Dark gradient overlay — stronger at bottom {%- endcomment -%}
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(0,0,0,0.08) 0%, rgba(0,0,0,0.25) 50%, rgba(0,0,0,0.72) 100%);"></div>
  </div>

  {%- comment -%} ── Minus / close icon — top-right ──────────────────────── {%- endcomment -%}
  <button
    class="absolute flex items-center justify-center bg-white bg-opacity-20 backdrop-blur-sm border border-white border-opacity-30 rounded-full text-white hover:bg-opacity-30 transition-all duration-200 z-10"
    style="top: 1.11vw; right: 1.11vw; width: 1.67vw; height: 1.67vw;"
    aria-label="Remove {{ block.settings.title }}"
  >
    <svg style="width: 0.83vw; height: 0.83vw;" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
      <line x1="2" y1="7" x2="12" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>

  {%- comment -%} ── All content — positioned at bottom ──────────────────── {%- endcomment -%}
  <div class="absolute inset-0 flex flex-col justify-end z-10" style="padding: 1.39vw 1.39vw 1.25vw;">

    {%- comment -%} Title {%- endcomment -%}
    <h3
      class="font-medium text-white leading-tight"
      style="font-size: 1.53vw; margin-bottom: 0.69vw;"
    >
      {{ block.settings.title | default: 'Voyage Bundle' }}
    </h3>

    {%- comment -%} Tags row {%- endcomment -%}
    {%- if block.settings.tag_1 != blank or block.settings.tag_2 != blank -%}
      <div class="flex items-center flex-wrap" style="gap: 0.56vw; margin-bottom: 1.39vw;">

        {%- if block.settings.tag_1 != blank -%}
          <span
            class="text-white font-normal"
            style="font-size: 0.97vw;"
          >{{ block.settings.tag_1 }}</span>
        {%- endif -%}

        {%- if block.settings.tag_2 != blank -%}
          <span
            class="text-white border border-white font-normal"
            style="font-size: 0.83vw; padding: 0.14vw 0.56vw; border-radius: 0.21vw;"
          >{{ block.settings.tag_2 }}</span>
        {%- endif -%}

      </div>
    {%- endif -%}

    {%- comment -%} ── Divider ─────────────────────────────────────────────── {%- endcomment -%}
    <div class="w-full bg-white bg-opacity-25" style="height: 1px; margin-bottom: 1.11vw;"></div>

    {%- comment -%} ── Bottom row: price left / options right ───────────────── {%- endcomment -%}
    <div class="flex items-end justify-between" style="margin-bottom: 1.11vw;">

      {%- comment -%} Price + save {%- endcomment -%}
      <div>
        <span class="font-medium text-white block" style="font-size: 1.25vw;">
          {{ block.settings.price | default: '€195' }}
        </span>
      </div>

      {%- comment -%} Right block: subscription label + variants {%- endcomment -%}
      <div class="flex flex-col items-end" style="gap: 0.56vw;">

        {%- if block.settings.subscription_label != blank -%}
          <span
            class="text-white text-opacity-70 uppercase tracking-wider"
            style="font-size: 0.64vw; letter-spacing: 0.1em; opacity: 0.75;"
          >
            {{ block.settings.subscription_label }}
          </span>
        {%- endif -%}

        {%- comment -%} Variant options {%- endcomment -%}
        <div class="flex flex-col items-end" style="gap: 0.35vw;">

          {%- if block.settings.variant_1 != blank -%}
            <label
              class="flex items-center cursor-pointer"
              style="gap: 0.56vw;"
              x-on:click="selected = 'v1'"
            >
              <span
                class="text-white"
                style="font-size: 0.97vw;"
                :class="selected === 'v1' ? 'font-medium' : 'font-normal opacity-70'"
              >{{ block.settings.variant_1 }}</span>
              <span
                class="flex-shrink-0 rounded-full border border-white transition-colors duration-150"
                style="width: 0.97vw; height: 0.97vw;"
                :class="selected === 'v1'
                  ? 'bg-white'
                  : 'bg-transparent'"
              ></span>
            </label>
          {%- endif -%}

          {%- if block.settings.variant_2 != blank -%}
            <label
              class="flex items-center cursor-pointer"
              style="gap: 0.56vw;"
              x-on:click="selected = 'v2'"
            >
              <span
                class="text-white"
                style="font-size: 0.97vw;"
                :class="selected === 'v2' ? 'font-medium' : 'font-normal opacity-70'"
              >{{ block.settings.variant_2 }}</span>
              <span
                class="flex-shrink-0 rounded-full border border-white transition-colors duration-150"
                style="width: 0.97vw; height: 0.97vw;"
                :class="selected === 'v2'
                  ? 'bg-white'
                  : 'bg-transparent'"
              ></span>
            </label>
          {%- endif -%}

        </div>

        {%- if block.settings.save_text != blank -%}
          <span class="text-white uppercase tracking-wide" style="font-size: 0.69vw; letter-spacing: 0.08em; opacity: 0.85;">
            {{ block.settings.save_text }}
          </span>
        {%- endif -%}

      </div>

    </div>

    {%- comment -%} Add bundle button {%- endcomment -%}
    <a
      href="{{ block.settings.url | default: '#' }}"
      class="flex items-center justify-end gap-[0.42vw] bg-white bg-opacity-15 backdrop-blur-sm text-white font-medium border border-white border-opacity-30 hover:bg-opacity-25 transition-all duration-200 w-full"
      style="font-size: 0.97vw; padding: 0.69vw 1.25vw; border-radius: 0.28vw;"
    >
      Add bundle
      <span style="font-size: 1vw;">→</span>
    </a>

  </div>

</div>

<script>
  function bundleCardFeatured() {
    return {
      selected: 'v1'
    };
  }
</script>
