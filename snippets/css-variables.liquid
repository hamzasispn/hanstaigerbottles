{% style %}
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'HelveticaNeueRoman.otf' | asset_url }}) format('opentype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'HelveticaNeueItalic.ttf' | asset_url }}) format('truetype');
    font-weight: 400;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'HelveticaNeueLight.otf' | asset_url }}) format('opentype');
    font-weight: 300;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'HelveticaNeueLightItalic.otf' | asset_url }}) format('opentype');
    font-weight: 300;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'HelveticaNeueMedium.otf' | asset_url }}) format('opentype');
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'HelveticaNeueMediumItalic.otf' | asset_url }}) format('opentype');
    font-weight: 500;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'HelveticaNeueBold.otf' | asset_url }}) format('opentype');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'HelveticaNeueBoldItalic.otf' | asset_url }}) format('opentype');
    font-weight: 700;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'HelveticaNeueHeavy.otf' | asset_url }}) format('opentype');
    font-weight: 900;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'HelveticaNeueHeavyItalic.otf' | asset_url }}) format('opentype');
    font-weight: 900;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'HelveticaNeueBlack.otf' | asset_url }}) format('opentype');
    font-weight: 950;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'HelveticaNeueBlackItalic.otf' | asset_url }}) format('opentype');
    font-weight: 950;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'HelveticaNeueThin.otf' | asset_url }}) format('opentype');
    font-weight: 100;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'HelveticaNeueThinItalic.otf' | asset_url }}) format('opentype');
    font-weight: 100;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'HelveticaNeueUltraLight.otf' | asset_url }}) format('opentype');
    font-weight: 200;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'HelveticaNeueUltraLightItalic.otf' | asset_url }}) format('opentype');
    font-weight: 200;
    font-style: italic;
    font-display: swap;
  }

  :root {
    --font-primary--family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    --font-primary--style: normal;
    --font-primary--weight: 400;
    --page-width: {{ settings.max_page_width }};
    --page-margin: {{ settings.min_page_margin }}px;
    --color-primary: {{ settings.primary_color }};
    --color-primary-hover: {{ settings.hover_primary_color }};
    --color-background: {{ settings.background_color }};
    --color-foreground: {{ settings.foreground_color }};
    --style-border-radius-inputs: {{ settings.input_corner_radius }}px;
  }

  body {
    font-family: var(--font-primary--family);
  }
{% endstyle %}
