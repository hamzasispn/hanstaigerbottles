{% style %}
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'helvetica-neue-5/HelveticaNeueRoman.otf' | asset_url }}) format('opentype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Helvetica Neue';
    src: url({{ 'helvetica-neue-5/HelveticaNeueItalic.ttf' | asset_url }}) format('truetype');
    font-weight: 400;
    font-style: italic;
    font-display: swap;
  }
