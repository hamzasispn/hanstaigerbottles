{% comment %}
  Snippet: bundle-card.liquid → /snippets/
  Handles both COLLAPSED (narrow, light) and EXPANDED (wide, full-bleed dark) states.
  Parent x-data must expose: active, open(i), isActive(i), variants{}

  Parameters:
    block — Shopify block object
    idx   — forloop.index0 (integer, passed as Liquid variable)
{% endcomment %}

{%- assign i = idx -%}

<div
  x-bind:style="isActive({{ i }})
    ? 'flex: 3.5; min-width: 0;'
    : 'flex: 1; min-width: 0;'"
  class="relative overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)]"
  style="border-radius: 0.56vw; flex: 1;"
  {{ block.shopify_attributes }}
>

  {%- comment -%} ═══════════════════════════════════════════════════════════
      EXPANDED STATE — full-bleed image, dark overlay, rich content bottom
  ═══════════════════════════════════════════════════════════════════════ {%- endcomment -%}
  <div
    x-show="isActive({{ i }})"
    x-transition:enter="transition-opacity duration-300 delay-150"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition-opacity duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="absolute inset-0 flex flex-col"
  >

    {%- comment -%} Background image {%- endcomment -%}
    <div class="absolute inset-0">
      {%- if block.settings.image != blank -%}
        <img
          src="{{ block.settings.image | image_url: width: 1400 }}"
          alt="{{ block.settings.title }}"
          class="w-full h-full object-cover"
          loading="lazy"
        >
      {%- else -%}
        <div class="w-full h-full bg-gradient-to-br from-[#3a6070] via-[#1e3040] to-[#0a0f14]"></div>
      {%- endif -%}
      {%- comment -%} Gradient overlay — transparent top, dark bottom {%- endcomment -%}
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.20) 45%, rgba(0,0,0,0.75) 100%);"
      ></div>
    </div>

    {%- comment -%} Minus button — top right {%- endcomment -%}
    <button
      class="absolute z-20 flex items-center justify-center rounded-full border border-white border-opacity-50 text-white bg-black bg-opacity-20 hover:bg-opacity-35 transition-all duration-200"
      style="top: 1.11vw; right: 1.11vw; width: 1.67vw; height: 1.67vw;"
      aria-label="Close"
    >
      <svg style="width: 0.69vw; height: 0.69vw;" viewBox="0 0 12 2" fill="none">
        <line x1="0.5" y1="1" x2="11.5" y2="1" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    {%- comment -%} Content — pinned to bottom {%- endcomment -%}
    <div class="absolute inset-x-0 bottom-0 z-10" style="padding: 1.39vw 1.39vw 1.25vw;">

      {%- comment -%} Title {%- endcomment -%}
      <h3
        class="font-medium text-white leading-tight"
        style="font-size: 1.53vw; margin-bottom: 0.56vw;"
      >
        {{ block.settings.title | default: 'Bundle Name' }}
      </h3>

      {%- comment -%} Tags row {%- endcomment -%}
      {%- if block.settings.tag_1 != blank or block.settings.tag_2 != blank -%}
        <div class="flex items-center flex-wrap" style="gap: 0.56vw; margin-bottom: 1.25vw;">
          {%- if block.settings.tag_1 != blank -%}
            <span class="text-white" style="font-size: 0.97vw;">
              {{ block.settings.tag_1 }}
            </span>
          {%- endif -%}
          {%- if block.settings.tag_2 != blank -%}
            <span
              class="text-white border border-white"
              style="font-size: 0.83vw; padding: 0.14vw 0.56vw; border-radius: 0.21vw;"
            >{{ block.settings.tag_2 }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} Divider {%- endcomment -%}
      <div class="w-full bg-white bg-opacity-25" style="height: 1px; margin-bottom: 1.11vw;"></div>

      {%- comment -%} Bottom row: price left — subscription + variants + save right {%- endcomment -%}
      <div class="flex items-end justify-between" style="margin-bottom: 1.11vw;">

        {%- comment -%} Price {%- endcomment -%}
        <span class="font-medium text-white" style="font-size: 1.25vw;">
          {{ block.settings.price | default: '€00' }}
        </span>

        {%- comment -%} Right column {%- endcomment -%}
        <div class="flex flex-col items-end" style="gap: 0.42vw;">

          {%- if block.settings.subscription_label != blank -%}
            <span
              class="uppercase text-white"
              style="font-size: 0.64vw; letter-spacing: 0.10em; opacity: 0.75;"
            >{{ block.settings.subscription_label }}</span>
          {%- endif -%}

          {%- comment -%} Variant toggles — right-aligned, radio on right {%- endcomment -%}
          {%- if block.settings.variant_1 != blank -%}
            <label class="flex items-center cursor-pointer" style="gap: 0.56vw;">
              <span
                class="text-white transition-opacity duration-150"
                style="font-size: 0.97vw;"
                :class="variants[{{ i }}] === 'v1' ? 'opacity-100 font-medium' : 'opacity-60 font-normal'"
              >{{ block.settings.variant_1 }}</span>
              <span
                class="flex-shrink-0 rounded-full border border-white transition-colors duration-150"
                style="width: 0.97vw; height: 0.97vw;"
                :class="variants[{{ i }}] === 'v1' ? 'bg-white' : 'bg-transparent'"
                @click="variants[{{ i }}] = 'v1'"
              ></span>
            </label>
          {%- endif -%}

          {%- if block.settings.variant_2 != blank -%}
            <label class="flex items-center cursor-pointer" style="gap: 0.56vw;">
              <span
                class="text-white transition-opacity duration-150"
                style="font-size: 0.97vw;"
                :class="variants[{{ i }}] === 'v2' ? 'opacity-100 font-medium' : 'opacity-60 font-normal'"
              >{{ block.settings.variant_2 }}</span>
              <span
                class="flex-shrink-0 rounded-full border border-white transition-colors duration-150"
                style="width: 0.97vw; height: 0.97vw;"
                :class="variants[{{ i }}] === 'v2' ? 'bg-white' : 'bg-transparent'"
                @click="variants[{{ i }}] = 'v2'"
              ></span>
            </label>
          {%- endif -%}

          {%- if block.settings.save_text != blank -%}
            <span class="text-white uppercase" style="font-size: 0.69vw; letter-spacing: 0.08em; opacity: 0.80;">
              {{ block.settings.save_text }}
            </span>
          {%- endif -%}

        </div>
      </div>

      {%- comment -%} Add bundle button {%- endcomment -%}
      <a
        href="{{ block.settings.url | default: '#' }}"
        class="flex items-center justify-end bg-white bg-opacity-15 backdrop-blur-sm text-white font-medium border border-white border-opacity-30 hover:bg-opacity-28 transition-all duration-200 w-full"
        style="font-size: 0.97vw; padding: 0.69vw 1.25vw; border-radius: 0.28vw; gap: 0.42vw;"
      >
        Add bundle <span>→</span>
      </a>

    </div>
  </div>


  {%- comment -%} ═══════════════════════════════════════════════════════════
      COLLAPSED STATE — light card, small image top-left, + icon top-right
  ═══════════════════════════════════════════════════════════════════════ {%- endcomment -%}
  <div
    x-show="!isActive({{ i }})"
    x-transition:enter="transition-opacity duration-300 delay-100"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition-opacity duration-100"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="absolute inset-0 flex flex-col bg-[#F0F0F0]"
    style="padding: 1.11vw;"
  >

    {%- comment -%} Top zone: image + plus button {%- endcomment -%}
    <div class="relative flex-shrink-0" style="margin-bottom: 1.11vw; height: 13.19vw;">

      {%- comment -%} Product image — top-left {%- endcomment -%}
      <div
        class="absolute top-0 left-0 overflow-hidden"
        style="width: 9.72vw; height: 9.03vw; border-radius: 0.28vw;"
      >
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 280 }}"
            alt="{{ block.settings.title }}"
            class="w-full h-full object-cover"
            loading="lazy"
          >
        {%- else -%}
          <div class="w-full h-full bg-[#D8D8D8] flex items-center justify-center">
            {{ 'product-1' | placeholder_svg_tag: 'w-12 h-12 opacity-30' }}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Plus button — top-right, click to expand {%- endcomment -%}
      <button
        @click="open({{ i }})"
        class="absolute top-0 right-0 flex items-center justify-center bg-white rounded-full text-[#111111] hover:bg-[#111111] hover:text-white transition-colors duration-200"
        style="width: 1.67vw; height: 1.67vw;"
        aria-label="Open {{ block.settings.title }}"
      >
        <svg style="width: 0.69vw; height: 0.69vw;" viewBox="0 0 12 12" fill="none">
          <line x1="6" y1="0.5" x2="6" y2="11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="0.5" y1="6" x2="11.5" y2="6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>

    </div>

    {%- comment -%} Content — flexible, fills remaining height {%- endcomment -%}
    <div class="flex flex-col flex-1 justify-between">

      <div>
        {%- comment -%} Title {%- endcomment -%}
        <h3
          class="font-medium text-[#111111] leading-tight"
          style="font-size: 1.25vw; margin-bottom: 0.28vw;"
        >
          {{ block.settings.title | default: 'Bundle Name' }}
        </h3>

        {%- comment -%} Subtitle {%- endcomment -%}
        {%- if block.settings.subtitle != blank -%}
          <p
            class="text-[#888888]"
            style="font-size: 0.97vw; margin-bottom: 0.83vw;"
          >{{ block.settings.subtitle }}</p>
        {%- endif -%}

        {%- comment -%} Variant toggles — dot left of label {%- endcomment -%}
        <div class="flex flex-col" style="gap: 0.42vw;">

          {%- if block.settings.variant_1 != blank -%}
            <label class="flex items-center cursor-pointer" style="gap: 0.56vw;">
              <span
                class="flex-shrink-0 rounded-full border transition-colors duration-150"
                style="width: 0.97vw; height: 0.97vw;"
                :class="variants[{{ i }}] === 'v1'
                  ? 'bg-[#111111] border-[#111111]'
                  : 'bg-white border-[#CCCCCC]'"
                @click="variants[{{ i }}] = 'v1'"
              ></span>
              <span
                class="text-[#111111]"
                style="font-size: 0.97vw;"
                :class="variants[{{ i }}] === 'v1' ? 'font-medium' : 'font-normal'"
              >{{ block.settings.variant_1 }}</span>
            </label>
          {%- endif -%}

          {%- if block.settings.variant_2 != blank -%}
            <label class="flex items-center cursor-pointer" style="gap: 0.56vw;">
              <span
                class="flex-shrink-0 rounded-full border transition-colors duration-150"
                style="width: 0.97vw; height: 0.97vw;"
                :class="variants[{{ i }}] === 'v2'
                  ? 'bg-[#111111] border-[#111111]'
                  : 'bg-white border-[#CCCCCC]'"
                @click="variants[{{ i }}] = 'v2'"
              ></span>
              <span
                class="text-[#111111]"
                style="font-size: 0.97vw;"
                :class="variants[{{ i }}] === 'v2' ? 'font-medium' : 'font-normal'"
              >{{ block.settings.variant_2 }}</span>
            </label>
          {%- endif -%}

        </div>
      </div>

      {%- comment -%} Bottom: divider + price + button {%- endcomment -%}
      <div>
        <div class="w-full bg-[#DDDDDD]" style="height: 1px; margin: 1.11vw 0;"></div>

        <div class="flex items-center justify-between" style="margin-bottom: 0.83vw;">
          <span class="font-medium text-[#111111]" style="font-size: 1.11vw;">
            {{ block.settings.price | default: '€00' }}
          </span>
          {%- if block.settings.save_text != blank -%}
            <span class="text-[#888888] uppercase" style="font-size: 0.69vw; letter-spacing: 0.08em;">
              {{ block.settings.save_text }}
            </span>
          {%- endif -%}
        </div>

        <a
          href="{{ block.settings.url | default: '#' }}"
          class="flex items-center justify-center bg-[#EBEBEB] text-[#111111] font-medium border border-[#CCCCCC] hover:bg-[#111111] hover:text-white hover:border-[#111111] transition-all duration-200 w-full"
          style="font-size: 0.97vw; padding: 0.69vw 1.25vw; border-radius: 0.28vw; gap: 0.42vw;"
        >
          Add bundle <span>→</span>
        </a>
      </div>

    </div>
  </div>

</div>
