{% comment %}
  Snippet: bundle-card.liquid → /snippets/
  Parameters:
    block — Shopify block object
    idx   — forloop.index0 (integer)
{% endcomment %}

{%- assign i = idx -%}

<div
  x-bind:class="isActive({{ i }}) ? 'lg:flex-2 flex-1 min-w-0' : 'flex-1 min-w-0'"
  class="relative overflow-hidden transition-all duration-500 ease-in-out rounded-[2vw] lg:rounded-[0.56vw] h-[110vw] lg:h-auto !opacity-100"
  {{ block.shopify_attributes }}
>
  {%- comment -%} EXPANDED STATE {%- endcomment -%}
  <div
    x-show="isActive({{ i }})"
    class="absolute inset-0 flex flex-col"
  >
    <div class="absolute inset-0">
      {%- if block.settings.image != blank -%}
        <img
          src="{{ block.settings.image | image_url: width: 1400 }}"
          alt="{{ block.settings.title }}"
          class="w-full h-full object-cover"
          loading="lazy"
        >
      {%- else -%}
        <div class="w-full h-full bg-gradient-to-br from-[#3a6070] via-[#1e3040] to-[#0a0f14]"></div>
      {%- endif -%}
      <div class="absolute inset-0 bg-gradient-to-b from-black/5 via-black/20 to-black/75"></div>
    </div>

    <button
      class="absolute z-20 flex items-center justify-center rounded-full border border-white/50 text-white bg-black/20 hover:bg-black/35 transition-all duration-200 top-[3.5vw] right-[3.5vw] w-[6vw] h-[6vw] lg:top-[1.11vw] lg:right-[1.11vw] lg:w-[1.67vw] lg:h-[1.67vw]"
      aria-label="Close"
    >
      <svg class="w-[2.4vw] h-[2.4vw] lg:w-[0.69vw] lg:h-[0.69vw]" viewBox="0 0 12 2" fill="none">
        <line x1="0.5" y1="1" x2="11.5" y2="1" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="absolute inset-x-0 bottom-0 z-10 p-[3vw] lg:p-[0.833vw]">
      <div class="flex justify-between p-[4vw] lg:p-[1.389vw]">
        <div>
          <h3
            class="font-medium text-white text-[4vw] leading-[5.4vw] mb-[2vw] lg:text-[1.111vw] lg:leading-[1.528vw] lg:mb-[0.694vw]"
          >
            {{ block.settings.title | default: 'Bundle Name' }}
          </h3>

          {%- if block.settings.tag_1 != blank or block.settings.tag_2 != blank -%}
            <div class="flex items-center flex-wrap gap-[2vw] lg:gap-[0.556vw]">
              {%- if block.settings.tag_1 != blank -%}
                <span class="text-[#DFE0E3] text-[3vw] leading-[4vw] lg:text-[0.972vw] lg:leading-[1.389vw]">
                  {{ block.settings.tag_1 }}
                </span>
              {%- endif -%}
              {%- if block.settings.tag_2 != blank -%}
                <span
                  class="text-white border border-white text-[2.6vw] py-[0.5vw] px-[2vw] rounded-[0.7vw] lg:text-[0.83vw] lg:py-[0.14vw] lg:px-[0.56vw] lg:rounded-[0.21vw]"
                >
                  {{- block.settings.tag_2 -}}
                </span>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        <div>
          {%- if block.settings.subscription_label != blank -%}
            <span
              class="uppercase text-[#DFE0E3] text-[2.6vw] tracking-[0.1vw] mb-[3vw] lg:text-[0.833vw] lg:tracking-[0.028vw] lg:mb-[1.389vw] inline-block"
            >
              {{- block.settings.subscription_label -}}
            </span>
          {%- endif -%}

          {%- if block.settings.variant_1 != blank -%}
            <label
              class="flex items-center justify-end cursor-pointer gap-[2vw] mb-[2vw] lg:gap-[0.56vw] lg:mb-[0.694vw]"
              :class="variants[{{ i }}] === 'v1' ? 'opacity-100' : 'opacity-80'"
              @click="variants[{{ i }}] = 'v1'"
            >
              <span
                class="flex-shrink-0 rounded-full w-[3.4vw] h-[3.4vw] lg:w-[0.972vw] lg:h-[0.972vw] transition-colors duration-150 border-2 border-solid border-white"
                :class="variants[{{ i }}] === 'v1' ? 'bg-[#303236]' : 'bg-white'"
              ></span>
              <span class="text-white font-normal text-[3vw] leading-[3.6vw] lg:text-[0.972vw] lg:leading-[1.111vw]">
                {{- block.settings.variant_1 -}}
              </span>
            </label>
          {%- endif -%}

          {%- if block.settings.variant_2 != blank -%}
            <label
              class="flex items-center justify-end cursor-pointer gap-[2vw] lg:gap-[0.56vw]"
              :class="variants[{{ i }}] === 'v2' ? 'opacity-100' : 'opacity-80'"
              @click="variants[{{ i }}] = 'v2'"
            >
              <span
                class="flex-shrink-0 rounded-full w-[3.4vw] h-[3.4vw] lg:w-[0.972vw] lg:h-[0.972vw] transition-colors duration-150 border-2 border-solid border-white"
                :class="variants[{{ i }}] === 'v2' ? 'bg-[#303236]' : 'bg-white'"
              ></span>
              <span class="text-white font-normal text-[3vw] leading-[3.6vw] lg:text-[0.972vw] lg:leading-[1.111vw]">
                {{- block.settings.variant_2 -}}
              </span>
            </label>
          {%- endif -%}
        </div>
      </div>

      <div class="w-full bg-white/25 h-px mb-[4vw] lg:mb-[1.11vw]"></div>

      <div class="flex items-center justify-between mb-[4vw] p-[3vw] lg:mb-[1.11vw] lg:p-[0.833vw]">
        <span class="font-medium text-white text-[4.4vw] lg:text-[1.25vw]">
          {{ block.settings.price | default: '€00' }}
        </span>

        {%- if block.settings.save_text != blank -%}
          <span class="text-white font-medium uppercase text-[2.6vw] leading-[3.6vw] lg:text-[0.833vw] lg:leading-[1.181vw] tracking-[0.08em]">
            {{ block.settings.save_text }}
          </span>
        {%- endif -%}
      </div>

      <a
        href="{{ block.settings.url | default: '#' }}"
        class="flex items-center justify-center ml-auto bg-[#F4F4F5]/40 backdrop-blur-sm text-white text-[3vw] w-[30vw] px-[3vw] py-[2vw] gap-[3vw] lg:text-[0.972vw] lg:w-[8.958vw] lg:px-[0.833vw] lg:py-[0.556vw] lg:gap-[1.111vw] leading-tight lg:leading-[1.389vw]"
      >
        Add bundle <span> {% render 'button-arrow' %} </span>
      </a>
    </div>
  </div>

  {%- comment -%} COLLAPSED STATE {%- endcomment -%}
  <div
    x-show="!isActive({{ i }})"
    class="absolute inset-0 flex flex-col bg-[#F4F4F5] p-[4vw] lg:p-[1.11vw]"
  >
    <div class="relative flex-shrink-0 mb-[8vw] h-[40vw] lg:mb-[3.194vw] lg:h-[15.139vw]">
      <div
        class="absolute top-0 left-0 overflow-hidden w-[40vw] h-full lg:w-[15.139vw] rounded-[0.6vw] lg:rounded-[0.187vw]"
      >
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 280 }}"
            alt="{{ block.settings.title }}"
            class="w-full h-full object-cover"
            loading="lazy"
          >
        {%- else -%}
          <div class="w-full h-full bg-[#F4F4F5] flex items-center justify-center">
            {{ 'product-1' | placeholder_svg_tag: 'w-12 h-12 opacity-30' }}
          </div>
        {%- endif -%}
      </div>

      <button
        @click="open({{ i }})"
        class="absolute top-0 right-0 flex items-center justify-center bg-white rounded-full text-[#111111] hover:bg-[#111111] hover:text-white transition-colors duration-200 w-[6vw] h-[6vw] lg:w-[1.67vw] lg:h-[1.67vw]"
        aria-label="Open {{ block.settings.title }}"
      >
        <svg class="w-[2.4vw] h-[2.4vw] lg:w-[0.69vw] lg:h-[0.69vw]" viewBox="0 0 12 12" fill="none">
          <line x1="6" y1="0.5" x2="6" y2="11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="0.5" y1="6" x2="11.5" y2="6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="flex flex-col flex-1 justify-between">
      <div class="p-[4vw] lg:p-[1.389vw]">
        <h3
          class="font-medium text-[#222222] text-[4vw] leading-[5.4vw] tracking-[0.05vw] mb-[2vw] lg:text-[1.111vw] lg:leading-[1.528vw] lg:tracking-[0.014vw] lg:mb-[0.694vw]"
        >
          {{ block.settings.title | default: 'Bundle Name' }}
        </h3>

        {%- if block.settings.subtitle != blank -%}
          <p class="text-[#83868E] text-[3vw] leading-[4vw] mb-[1.5vw] lg:text-[0.972vw] lg:leading-[1.389vw] lg:mb-[0.556vw] font-normal">
            {{ block.settings.subtitle }}
          </p>
        {%- endif -%}

        <div class="flex flex-col gap-[1.5vw] lg:gap-[0.42vw]">
          {%- if block.settings.variant_1 != blank -%}
            <label
              class="flex items-center cursor-pointer gap-[2vw] lg:gap-[0.556vw]"
              :class="variants[{{ i }}] === 'v1' ? 'opacity-100' : 'opacity-20'"
              @click="variants[{{ i }}] = 'v1'"
            >
              <span
                class="flex-shrink-0 rounded-full w-[2.4vw] h-[2.4vw] lg:w-[0.694vw] lg:h-[0.694vw] bg-[#303236]"
              ></span>
              <span class="text-[#303236] font-normal text-[3vw] leading-[4vw] lg:text-[0.833vw] lg:leading-[1.111vw]">
                {{- block.settings.variant_1 -}}
              </span>
            </label>
          {%- endif -%}

          {%- if block.settings.variant_2 != blank -%}
            <label
              class="flex items-center cursor-pointer gap-[2vw] lg:gap-[0.556vw]"
              :class="variants[{{ i }}] === 'v2' ? 'opacity-100' : 'opacity-20'"
              @click="variants[{{ i }}] = 'v2'"
            >
              <span
                class="flex-shrink-0 rounded-full w-[2.4vw] h-[2.4vw] lg:w-[0.694vw] lg:h-[0.694vw] bg-[#303236]"
              ></span>
              <span class="text-[#303236] font-normal text-[3vw] leading-[4vw] lg:text-[0.833vw] lg:leading-[1.111vw]">
                {{- block.settings.variant_2 -}}
              </span>
            </label>
          {%- endif -%}
        </div>
      </div>

      <div>
        <div class="w-full bg-[#DDDDDD] h-px my-[4vw] lg:my-[1.11vw]"></div>

        <div class="flex items-center justify-between p-[4vw] lg:p-[1.389vw]">
          <span class="font-medium text-[#4F5257] text-[4vw] lg:text-[1.11vw]">
            {{ block.settings.price | default: '€00' }}
          </span>
          {%- if block.settings.save_text != blank -%}
            <span class="text-[#83868E] font-medium uppercase text-[2.6vw] leading-[3.6vw] lg:text-[0.833vw] lg:leading-[1.181vw] tracking-[0.08em]">
              {{ block.settings.save_text }}
            </span>
          {%- endif -%}
        </div>

        <a
          href="{{ block.settings.url | default: '#' }}"
          class="flex items-center justify-center ml-auto bg-[#EBEBEB] text-[#111111] text-[3vw] w-[30vw] px-[3vw] py-[2vw] gap-[3vw] lg:text-[0.972vw] lg:w-[8.958vw] lg:px-[0.833vw] lg:py-[0.556vw] lg:gap-[1.111vw] leading-tight lg:leading-[1.389vw]"
        >
          Add bundle <span> {% render 'button-arrow' %} </span>
        </a>
      </div>
    </div>
  </div>
</div>
